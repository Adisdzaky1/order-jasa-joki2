<%# views/partials/footer.ejs %>
<footer class="bg-gray-900 border-t border-gray-800 mt-auto">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">

      <%# Brand %>
      <div>
        <a href="/" class="flex items-center gap-2 mb-4">
          <div class="w-8 h-8 rounded-lg bg-indigo-600 flex items-center justify-center font-bold text-sm">JT</div>
          <span class="font-bold text-white text-lg">JasaTugas<span class="text-indigo-400">.id</span></span>
        </a>
        <p class="text-gray-400 text-sm leading-relaxed">
          Solusi terpercaya untuk tugas akademik & profesional Anda. Dikerjakan oleh tenaga ahli berpengalaman.
        </p>
      </div>

      <%# Links %>
      <div>
        <h3 class="text-sm font-semibold text-white mb-4">Navigasi</h3>
        <ul class="space-y-2">
          <li><a href="/" class="text-gray-400 hover:text-white text-sm transition-colors">Beranda</a></li>
          <li><a href="/layanan" class="text-gray-400 hover:text-white text-sm transition-colors">Layanan</a></li>
          <li><a href="/dashboard" class="text-gray-400 hover:text-white text-sm transition-colors">Dashboard</a></li>
        </ul>
      </div>

      <%# Contact %>
      <div>
        <h3 class="text-sm font-semibold text-white mb-4">Kontak</h3>
        <ul class="space-y-2">
          <li class="flex items-center gap-2 text-gray-400 text-sm">
            <svg class="w-4 h-4 text-indigo-400 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
            </svg>
            support@jasatugas.id
          </li>
          <li class="flex items-center gap-2 text-gray-400 text-sm">
            <svg class="w-4 h-4 text-indigo-400 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
            Senin – Sabtu, 08.00 – 22.00
          </li>
        </ul>
      </div>
    </div>

    <div class="border-t border-gray-800 mt-10 pt-6 flex flex-col sm:flex-row items-center justify-between gap-4">
      <p class="text-gray-500 text-sm">&copy; <%= new Date().getFullYear() %> JasaTugas.id. All rights reserved.</p>
      <p class="text-gray-600 text-xs">Dibuat dengan ❤️ di Indonesia</p>
    </div>
  </div>
</footer>
