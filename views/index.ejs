<%# views/index.ejs %>
<% layout('layouts/main') %>
<% title = 'Beranda' %>

<%# ── HERO ─────────────────────────────────────────────────────────────────── %>
<section class="relative overflow-hidden">
  <%# Gradient blob background %>
  <div class="absolute inset-0 pointer-events-none">
    <div class="absolute -top-40 -left-40 w-96 h-96 bg-indigo-600/20 rounded-full blur-3xl"></div>
    <div class="absolute -top-20 right-0 w-80 h-80 bg-violet-600/15 rounded-full blur-3xl"></div>
  </div>

  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-24 pb-20 text-center">
    <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-indigo-500/10 border border-indigo-500/20 text-indigo-400 text-xs font-medium mb-6">
      <span class="w-1.5 h-1.5 rounded-full bg-indigo-400 animate-pulse"></span>
      Dipercaya 500+ Mahasiswa Indonesia
    </div>

    <h1 class="text-4xl sm:text-5xl lg:text-6xl font-extrabold text-white leading-tight mb-6">
      Selesaikan Tugasmu<br/>
      <span class="text-transparent bg-clip-text bg-gradient-to-r from-indigo-400 to-violet-400">
        Lebih Cepat & Mudah
      </span>
    </h1>

    <p class="text-lg text-gray-400 max-w-2xl mx-auto mb-10 leading-relaxed">
      Layanan jasa pengerjaan tugas akademik profesional — skripsi, makalah, laporan, hingga coding.
      Dijamin tepat waktu, original, dan berkualitas.
    </p>

    <div class="flex flex-col sm:flex-row gap-4 justify-center">
      <a href="/layanan"
         class="px-8 py-3.5 bg-indigo-600 hover:bg-indigo-500 text-white font-semibold rounded-xl transition-all duration-200 hover:shadow-lg hover:shadow-indigo-500/25 text-sm">
        Pesan Sekarang →
      </a>
      <a href="#cara-kerja"
         class="px-8 py-3.5 border border-gray-700 hover:border-gray-500 text-gray-300 hover:text-white font-semibold rounded-xl transition-colors text-sm">
        Cara Kerja
      </a>
    </div>

    <%# Trust badges %>
    <div class="flex flex-wrap items-center justify-center gap-6 mt-14">
      <% [['500+','Pelanggan'], ['98%','Kepuasan'], ['24h','Respon Cepat'], ['3x','Revisi Gratis']].forEach(([val,lab]) => { %>
        <div class="text-center">
          <div class="text-2xl font-extrabold text-white"><%= val %></div>
          <div class="text-xs text-gray-500 mt-0.5"><%= lab %></div>
        </div>
      <% }) %>
    </div>
  </div>
</section>

<%# ── CARA KERJA ──────────────────────────────────────────────────────────── %>
<section id="cara-kerja" class="py-20 bg-gray-900/50">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-14">
      <h2 class="text-3xl font-bold text-white mb-3">Cara Kerja</h2>
      <p class="text-gray-400">3 langkah mudah, tugas beres!</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 relative">
      <%# Connector line (desktop only) %>
      <div class="hidden md:block absolute top-10 left-[calc(33%+2rem)] right-[calc(33%+2rem)] h-px bg-gradient-to-r from-indigo-600 to-violet-600 opacity-30"></div>

      <% [
        { step:'01', icon:'🛒', title:'Pilih & Pesan', desc:'Pilih layanan yang sesuai kebutuhan, isi detail tugas dan upload file referensi jika ada.' },
        { step:'02', icon:'💳', title:'Bayar via QRIS', desc:'Bayar dengan QRIS atau e-wallet favorit. Pembayaran aman dan terverifikasi otomatis.' },
        { step:'03', icon:'📥', title:'Terima Hasil', desc:'Kami kerjakan pesanan Anda. Download hasilnya langsung dari dashboard ketika selesai.' }
      ].forEach(item => { %>
        <div class="relative bg-gray-900 border border-gray-800 rounded-2xl p-6 hover:border-indigo-500/50 transition-all duration-300 group">
          <div class="absolute -top-3 left-6 px-2.5 py-0.5 bg-indigo-600 rounded-full text-xs font-bold text-white"><%= item.step %></div>
          <div class="text-4xl mb-4 mt-2"><%= item.icon %></div>
          <h3 class="text-lg font-semibold text-white mb-2"><%= item.title %></h3>
          <p class="text-gray-400 text-sm leading-relaxed"><%= item.desc %></p>
        </div>
      <% }) %>
    </div>
  </div>
</section>

<%# ── LAYANAN ─────────────────────────────────────────────────────────────── %>
<section class="py-20">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-14">
      <h2 class="text-3xl font-bold text-white mb-3">Layanan Kami</h2>
      <p class="text-gray-400">Berbagai solusi untuk kebutuhan akademik & profesional Anda</p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
      <% services.forEach(sv => { %>
        <div class="bg-gray-900 border border-gray-800 rounded-2xl p-6 hover:border-indigo-500 transition-all duration-300 hover:shadow-lg hover:shadow-indigo-500/10 flex flex-col">
          <div class="text-3xl mb-3"><%= sv.icon %></div>
          <h3 class="font-semibold text-white mb-1.5"><%= sv.name %></h3>
          <p class="text-gray-400 text-sm leading-relaxed flex-1 mb-4"><%= sv.description %></p>
          <div class="flex items-center justify-between mt-auto">
            <div>
              <p class="text-xs text-gray-500">Mulai dari</p>
              <p class="text-indigo-400 font-bold">Rp <%= sv.price.toLocaleString('id-ID') %></p>
            </div>
            <span class="text-xs text-gray-500 bg-gray-800 px-2.5 py-1 rounded-full"><%= sv.estimasi %></span>
          </div>
          <a href="/pesan/<%= sv.id %>"
             class="mt-4 block text-center bg-indigo-600 hover:bg-indigo-500 text-white text-sm font-semibold py-2.5 rounded-xl transition-colors">
            Pesan
          </a>
        </div>
      <% }) %>
    </div>

    <div class="text-center mt-10">
      <a href="/layanan" class="inline-flex items-center gap-2 text-indigo-400 hover:text-indigo-300 text-sm font-medium transition-colors">
        Lihat Semua Layanan
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
        </svg>
      </a>
    </div>
  </div>
</section>

<%# ── TESTIMONI ───────────────────────────────────────────────────────────── %>
<section class="py-20 bg-gray-900/50">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-14">
      <h2 class="text-3xl font-bold text-white mb-3">Apa Kata Mereka</h2>
      <p class="text-gray-400">Kepuasan pelanggan adalah prioritas utama kami</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-5">
      <% [
        { name:'Rina A.', role:'Mahasiswa Universitas Indonesia', text:'Skripsi saya selesai tepat waktu dan hasilnya memuaskan. Revisi dilayani dengan cepat dan ramah. Highly recommended!', rating:5 },
        { name:'Budi S.', role:'Mahasiswa Telkom University', text:'Awalnya ragu, tapi ternyata hasilnya luar biasa! Makalah saya dapat nilai A. Pasti bakal order lagi.', rating:5 },
        { name:'Citra M.', role:'Mahasiswa BINUS University', text:'Prosesnya mudah banget. Upload brief, bayar, tinggal tunggu. File hasilnya rapi dan sesuai instruksi dosen.', rating:5 },
      ].forEach(t => { %>
        <div class="bg-gray-900 border border-gray-800 rounded-2xl p-6">
          <div class="flex gap-0.5 mb-4">
            <% for(let i=0;i<t.rating;i++) { %><span class="text-yellow-400 text-sm">★</span><% } %>
          </div>
          <p class="text-gray-300 text-sm leading-relaxed mb-6">"<%= t.text %>"</p>
          <div class="flex items-center gap-3">
            <div class="w-9 h-9 rounded-full bg-indigo-600/30 flex items-center justify-center text-indigo-400 font-bold text-sm">
              <%= t.name.charAt(0) %>
            </div>
            <div>
              <p class="text-white text-sm font-semibold"><%= t.name %></p>
              <p class="text-gray-500 text-xs"><%= t.role %></p>
            </div>
          </div>
        </div>
      <% }) %>
    </div>
  </div>
</section>

<%# ── FAQ ────────────────────────────────────────────────────────────────── %>
<section class="py-20">
  <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-14">
      <h2 class="text-3xl font-bold text-white mb-3">FAQ</h2>
      <p class="text-gray-400">Pertanyaan yang sering ditanyakan</p>
    </div>

    <div class="space-y-3" id="faq-list">
      <% [
        { q:'Apakah hasil pekerjaan dijamin original?', a:'Ya! Semua pekerjaan dikerjakan dari nol oleh tenaga ahli kami. Setiap karya melewati pengecekan plagiarisme sebelum diserahkan.' },
        { q:'Berapa lama proses pengerjaannya?', a:'Tergantung jenis layanan. Umumnya 3–14 hari kerja. Estimasi waktu tertera di setiap layanan. Kami juga menyediakan layanan express dengan biaya tambahan.' },
        { q:'Bagaimana jika saya tidak puas dengan hasilnya?', a:'Kami memberikan revisi gratis hingga 3 kali. Jika masih tidak sesuai, kami siap mendiskusikan solusi terbaik bersama Anda.' },
        { q:'Metode pembayaran apa yang diterima?', a:'Kami menerima QRIS (semua bank/e-wallet), OVO, DANA, ShopeePay, dan LinkAja. Pembayaran aman dan terverifikasi otomatis.' },
        { q:'Apakah data dan identitas saya aman?', a:'Tentu! Kami menjaga kerahasiaan data pelanggan sepenuhnya. Informasi Anda tidak pernah dibagikan kepada pihak ketiga.' },
      ].forEach((item, i) => { %>
        <div class="bg-gray-900 border border-gray-800 rounded-2xl overflow-hidden">
          <button class="faq-btn w-full flex items-center justify-between px-6 py-4 text-left hover:bg-gray-800/50 transition-colors"
                  data-target="faq-<%= i %>">
            <span class="text-sm font-medium text-white"><%= item.q %></span>
            <svg class="w-4 h-4 text-gray-400 shrink-0 transition-transform duration-200 faq-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
            </svg>
          </button>
          <div id="faq-<%= i %>" class="hidden px-6 pb-4">
            <p class="text-sm text-gray-400 leading-relaxed"><%= item.a %></p>
          </div>
        </div>
      <% }) %>
    </div>
  </div>
</section>

<%# ── CTA BOTTOM ─────────────────────────────────────────────────────────── %>
<section class="py-20 bg-gradient-to-r from-indigo-600/10 to-violet-600/10 border-y border-gray-800">
  <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
    <h2 class="text-3xl font-bold text-white mb-4">Siap Mulai Sekarang?</h2>
    <p class="text-gray-400 mb-8">Daftarkan akun gratis dan pesan layanan pertama Anda hari ini.</p>
    <a href="/register"
       class="inline-block px-10 py-3.5 bg-indigo-600 hover:bg-indigo-500 text-white font-semibold rounded-xl transition-all duration-200 hover:shadow-lg hover:shadow-indigo-500/25">
      Buat Akun Gratis
    </a>
  </div>
</section>

<script>
// FAQ Accordion
document.querySelectorAll('.faq-btn').forEach(btn => {
  btn.addEventListener('click', () => {
    const target = document.getElementById(btn.dataset.target);
    const icon = btn.querySelector('.faq-icon');
    const isOpen = !target.classList.contains('hidden');

    // Tutup semua
    document.querySelectorAll('[id^="faq-"]').forEach(el => el.classList.add('hidden'));
    document.querySelectorAll('.faq-icon').forEach(ic => ic.style.transform = '');

    // Toggle yang diklik
    if (!isOpen) {
      target.classList.remove('hidden');
      icon.style.transform = 'rotate(180deg)';
    }
  });
});
</script>
