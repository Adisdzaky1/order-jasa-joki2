<%# views/register.ejs %>
<% layout('layouts/main') %>
<% title = 'Daftar Akun' %>

<section class="min-h-[calc(100vh-4rem)] flex items-center justify-center px-4 py-12">
  <div class="w-full max-w-md">

    <div class="text-center mb-8">
      <a href="/" class="inline-flex items-center gap-2 mb-6">
        <div class="w-10 h-10 rounded-xl bg-indigo-600 flex items-center justify-center font-bold">JT</div>
      </a>
      <h1 class="text-2xl font-bold text-white">Buat Akun Baru</h1>
      <p class="text-gray-400 text-sm mt-2">Sudah punya akun? <a href="/login" class="text-indigo-400 hover:text-indigo-300 font-medium">Masuk di sini</a></p>
    </div>

    <div class="bg-gray-900 border border-gray-800 rounded-2xl p-8">
      <div id="error-msg" class="hidden mb-5 p-3.5 bg-red-950 border border-red-800 rounded-xl text-sm text-red-400"></div>
      <div id="success-msg" class="hidden mb-5 p-3.5 bg-green-950 border border-green-800 rounded-xl text-sm text-green-400">
        Akun berhasil dibuat! Mengarahkan ke halaman login...
      </div>

      <div class="space-y-4">
        <div>
          <label class="block text-sm font-medium text-gray-300 mb-2">Nama Lengkap</label>
          <input id="name" type="text" placeholder="Masukkan nama lengkap" autocomplete="name"
                 class="w-full bg-gray-800 border border-gray-700 rounded-xl px-4 py-3 text-gray-100
                        focus:outline-none focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500 transition-colors text-sm"/>
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-300 mb-2">Email</label>
          <input id="email" type="email" placeholder="nama@email.com" autocomplete="email"
                 class="w-full bg-gray-800 border border-gray-700 rounded-xl px-4 py-3 text-gray-100
                        focus:outline-none focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500 transition-colors text-sm"/>
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-300 mb-2">Password</label>
          <input id="password" type="password" placeholder="Minimal 8 karakter"
                 class="w-full bg-gray-800 border border-gray-700 rounded-xl px-4 py-3 text-gray-100
                        focus:outline-none focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500 transition-colors text-sm"/>
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-300 mb-2">Konfirmasi Password</label>
          <input id="confirm-password" type="password" placeholder="Ulangi password"
                 class="w-full bg-gray-800 border border-gray-700 rounded-xl px-4 py-3 text-gray-100
                        focus:outline-none focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500 transition-colors text-sm"/>
        </div>
        <button id="register-btn"
                class="w-full bg-indigo-600 hover:bg-indigo-500 text-white font-semibold py-3 px-6 rounded-xl transition-colors duration-200 text-sm flex items-center justify-center gap-2 disabled:opacity-60 mt-2">
          <span id="btn-text">Buat Akun</span>
          <svg id="btn-spinner" class="hidden w-4 h-4 animate-spin" fill="none" viewBox="0 0 24 24">
            <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"/>
            <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8v8H4z"/>
          </svg>
        </button>
      </div>

      <p class="text-center text-xs text-gray-500 mt-5">
        Dengan mendaftar, Anda menyetujui syarat & ketentuan layanan kami.
      </p>
    </div>
  </div>
</section>

<script src="https://www.gstatic.com/firebasejs/10.7.1/firebase-app-compat.js"></script>
<script src="https://www.gstatic.com/firebasejs/10.7.1/firebase-auth-compat.js"></script>
<script>
  firebase.initializeApp({
    apiKey: '<%= firebaseApiKey %>',
    authDomain: '<%= firebaseAuthDomain %>'
  });
  const auth = firebase.auth();

  const errEl = document.getElementById('error-msg');
  const sucEl = document.getElementById('success-msg');
  const btn = document.getElementById('register-btn');
  const btnText = document.getElementById('btn-text');
  const spinner = document.getElementById('btn-spinner');

  function setLoading(v) {
    btn.disabled = v;
    btnText.textContent = v ? 'Memproses...' : 'Buat Akun';
    spinner.classList.toggle('hidden', !v);
  }

  btn.addEventListener('click', async () => {
    const name = document.getElementById('name').value.trim();
    const email = document.getElementById('email').value.trim();
    const password = document.getElementById('password').value;
    const confirm = document.getElementById('confirm-password').value;

    errEl.classList.add('hidden');

    if (!name || !email || !password || !confirm) {
      errEl.textContent = 'Semua field wajib diisi.';
      return errEl.classList.remove('hidden');
    }
    if (password.length < 8) {
      errEl.textContent = 'Password minimal 8 karakter.';
      return errEl.classList.remove('hidden');
    }
    if (password !== confirm) {
      errEl.textContent = 'Password dan konfirmasi tidak cocok.';
      return errEl.classList.remove('hidden');
    }

    setLoading(true);
    try {
      const cred = await auth.createUserWithEmailAndPassword(email, password);
      const uid = cred.user.uid;

      const res = await fetch('/api/auth/register', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ uid, name, email })
      });
      const data = await res.json();

      if (data.success) {
        sucEl.classList.remove('hidden');
        setTimeout(() => window.location.href = '/login', 1500);
      } else {
        throw new Error(data.error || 'Registrasi gagal');
      }
    } catch (err) {
      const msg = {
        'auth/email-already-in-use': 'Email sudah terdaftar.',
        'auth/invalid-email': 'Format email tidak valid.',
        'auth/weak-password': 'Password terlalu lemah.',
      }[err.code] || err.message || 'Terjadi kesalahan.';
      errEl.textContent = msg;
      errEl.classList.remove('hidden');
    } finally {
      setLoading(false);
    }
  });
</script>
