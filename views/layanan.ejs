<%# views/layanan.ejs %>
<% title = 'Layanan Kami' %>

<section class="py-12 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

  <%# Header %>
  <div class="mb-10">
    <h1 class="text-3xl font-bold text-white mb-2">Layanan Kami</h1>
    <p class="text-gray-400">Pilih layanan yang sesuai dengan kebutuhan Anda</p>
  </div>

  <%# Search & Filter %>
  <div class="flex flex-col sm:flex-row gap-3 mb-8">
    <div class="relative flex-1">
      <svg class="absolute left-3.5 top-1/2 -translate-y-1/2 w-4 h-4 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
      </svg>
      <input id="search" type="text" placeholder="Cari layanan..."
             class="w-full bg-gray-800 border border-gray-700 rounded-xl pl-10 pr-4 py-3 text-gray-100
                    focus:outline-none focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500 transition-colors text-sm"/>
    </div>
    <select id="filter-cat"
            class="bg-gray-800 border border-gray-700 rounded-xl px-4 py-3 text-gray-300
                   focus:outline-none focus:border-indigo-500 transition-colors text-sm min-w-[160px]">
      <option value="">Semua Kategori</option>
      <option value="akademik">Akademik</option>
      <option value="coding">Coding</option>
      <option value="desain">Desain</option>
      <option value="lainnya">Lainnya</option>
    </select>
  </div>

  <%# Grid Layanan %>
  <div id="services-grid" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
    <% services.forEach(sv => { %>
      <div class="service-card bg-gray-900 border border-gray-800 rounded-2xl p-6
                  hover:border-indigo-500 transition-all duration-300 hover:shadow-lg
                  hover:shadow-indigo-500/10 flex flex-col"
           data-name="<%= sv.name.toLowerCase() %>"
           data-desc="<%= sv.description.toLowerCase() %>"
           data-cat="<%= sv.category %>">

        <div class="flex items-start justify-between mb-4">
          <div class="text-3xl"><%= sv.icon %></div>
          <span class="text-xs bg-indigo-500/10 text-indigo-400 border border-indigo-500/20 px-2.5 py-1 rounded-full capitalize"><%= sv.category %></span>
        </div>

        <h3 class="font-semibold text-white text-base mb-2"><%= sv.name %></h3>
        <p class="text-gray-400 text-sm leading-relaxed flex-1 mb-4"><%= sv.description %></p>

        <%# Fitur %>
        <ul class="space-y-1.5 mb-5">
          <% sv.features.forEach(f => { %>
            <li class="flex items-center gap-2 text-xs text-gray-400">
              <svg class="w-3.5 h-3.5 text-indigo-400 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/>
              </svg>
              <%= f %>
            </li>
          <% }) %>
        </ul>

        <%# Harga + CTA %>
        <div class="border-t border-gray-800 pt-4 mt-auto">
          <div class="flex items-center justify-between mb-3">
            <div>
              <p class="text-xs text-gray-500">Mulai dari</p>
              <p class="text-indigo-400 font-bold text-lg">Rp <%= sv.price.toLocaleString('id-ID') %></p>
            </div>
            <div class="text-right">
              <p class="text-xs text-gray-500">Estimasi</p>
              <p class="text-gray-300 text-sm font-medium"><%= sv.estimasi %></p>
            </div>
          </div>
          <a href="/pesan/<%= sv.id %>"
             class="block w-full text-center bg-indigo-600 hover:bg-indigo-500 text-white font-semibold py-2.5 rounded-xl transition-colors text-sm">
            Pesan Sekarang
          </a>
        </div>
      </div>
    <% }) %>

    <%# ── Card Jasa Custom (selalu muncul, tidak terpengaruh filter) ── %>
    <div class="service-card bg-gradient-to-br from-violet-900/40 to-indigo-900/40 border border-violet-700/50
                rounded-2xl p-6 hover:border-violet-500 transition-all duration-300
                hover:shadow-lg hover:shadow-violet-500/15 flex flex-col"
         data-name="jasa custom" data-desc="custom bebas negosiasi" data-cat="custom">

      <div class="flex items-start justify-between mb-4">
        <div class="text-3xl">✨</div>
        <span class="text-xs bg-violet-500/20 text-violet-400 border border-violet-500/30 px-2.5 py-1 rounded-full">Custom</span>
      </div>

      <h3 class="font-semibold text-white text-base mb-2">Jasa Custom</h3>
      <p class="text-gray-400 text-sm leading-relaxed flex-1 mb-4">
        Kebutuhan khusus yang tidak ada di daftar layanan? Ceritakan kepada kami! Admin akan mendiskusikan detail dan harga langsung dengan Anda.
      </p>

      <ul class="space-y-1.5 mb-5">
        <% [
          'Semua jenis pekerjaan diterima',
          'Harga sesuai kesepakatan',
          'Konsultasi gratis sebelum mulai',
          'Deposit awal Rp 25.000',
        ].forEach(f => { %>
          <li class="flex items-center gap-2 text-xs text-gray-400">
            <svg class="w-3.5 h-3.5 text-violet-400 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/>
            </svg>
            <%= f %>
          </li>
        <% }) %>
      </ul>

      <div class="border-t border-violet-700/30 pt-4 mt-auto">
        <div class="flex items-center justify-between mb-3">
          <div>
            <p class="text-xs text-gray-500">Deposit awal</p>
            <p class="text-violet-400 font-bold text-lg">Rp 25.000</p>
          </div>
          <div class="text-right">
            <p class="text-xs text-gray-500">Estimasi</p>
            <p class="text-gray-300 text-sm font-medium">Diskusi dulu</p>
          </div>
        </div>
        <a href="/pesan/custom"
           class="block w-full text-center bg-violet-600 hover:bg-violet-500 text-white font-semibold py-2.5 rounded-xl transition-colors text-sm">
          Pesan Custom
        </a>
      </div>
    </div>
  </div>

  <%# Empty state %>
  <div id="empty-state" class="hidden text-center py-20">
    <div class="text-4xl mb-4">🔍</div>
    <h3 class="text-lg font-semibold text-white mb-2">Layanan tidak ditemukan</h3>
    <p class="text-gray-400 text-sm">Coba kata kunci atau filter yang berbeda</p>
  </div>
</section>

<script>
  const searchEl = document.getElementById('search');
  const filterEl = document.getElementById('filter-cat');
  const cards = document.querySelectorAll('.service-card');
  const emptyEl = document.getElementById('empty-state');

  function filterCards() {
    const q = searchEl.value.toLowerCase();
    const cat = filterEl.value;
    let visible = 0;

    cards.forEach(card => {
      const matchQ = !q || card.dataset.name.includes(q) || card.dataset.desc.includes(q);
      const matchCat = !cat || card.dataset.cat === cat;
      const show = matchQ && matchCat;
      card.style.display = show ? '' : 'none';
      if (show) visible++;
    });

    emptyEl.classList.toggle('hidden', visible > 0);
  }

  searchEl.addEventListener('input', filterCards);
  filterEl.addEventListener('change', filterCards);
</script>
