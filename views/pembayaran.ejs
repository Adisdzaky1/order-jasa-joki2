<%# views/pembayaran.ejs %>
<% layout('layouts/main') %>
<% title = 'Pembayaran' %>

<section class="py-12 max-w-2xl mx-auto px-4 sm:px-6 lg:px-8">

  <%# Step Indicator %>
  <div class="flex items-center gap-0 mb-10">
    <% [['1','Detail Tugas'], ['2','Pembayaran'], ['3','Selesai']].forEach(([n,label], i) => { %>
      <div class="flex items-center <%= i < 2 ? 'flex-1' : '' %>">
        <div class="flex items-center gap-2">
          <div class="w-8 h-8 rounded-full flex items-center justify-center text-sm font-bold
                      <%= n === '1' ? 'bg-green-600 text-white' : n === '2' ? 'bg-indigo-600 text-white' : 'bg-gray-800 text-gray-500 border border-gray-700' %>">
            <% if (n === '1') { %>
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/>
              </svg>
            <% } else { %><%= n %><% } %>
          </div>
          <span class="text-sm <%= n === '2' ? 'text-white font-medium' : n === '1' ? 'text-green-400' : 'text-gray-500' %> hidden sm:block"><%= label %></span>
        </div>
        <% if (i < 2) { %>
          <div class="flex-1 h-px mx-3 <%= i === 0 ? 'bg-green-600/50' : 'bg-gray-800' %>"></div>
        <% } %>
      </div>
    <% }) %>
  </div>

  <%# Ringkasan Order %>
  <div class="bg-gray-900 border border-gray-800 rounded-2xl p-5 mb-5">
    <h3 class="text-sm font-semibold text-gray-400 uppercase tracking-wider mb-3">Ringkasan Pesanan</h3>
    <div class="flex justify-between items-start">
      <div>
        <p class="text-white font-medium"><%= order.service_name %></p>
        <p class="text-sm text-gray-400 mt-0.5 truncate max-w-xs"><%= order.title %></p>
      </div>
      <p class="text-indigo-400 font-bold text-lg shrink-0 ml-4">Rp <%= order.price.toLocaleString('id-ID') %></p>
    </div>
  </div>

  <%# ── STEP A: Pilih Metode ─────────────────────────────────────────────── %>
  <div id="step-method" class="bg-gray-900 border border-gray-800 rounded-2xl p-6">
    <h2 class="text-lg font-semibold text-white mb-5">Pilih Metode Pembayaran</h2>

    <div id="methods-loading" class="text-center py-8">
      <svg class="w-6 h-6 animate-spin text-indigo-400 mx-auto mb-2" fill="none" viewBox="0 0 24 24">
        <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"/>
        <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8v8H4z"/>
      </svg>
      <p class="text-sm text-gray-400">Memuat metode pembayaran...</p>
    </div>

    <div id="methods-grid" class="grid grid-cols-2 sm:grid-cols-3 gap-3 hidden"></div>
    <div id="methods-error" class="hidden text-center py-6 text-sm text-red-400">Gagal memuat metode. <button onclick="loadMethods()" class="underline">Coba lagi</button></div>

    <div id="method-error" class="hidden mt-4 p-3 bg-red-950 border border-red-800 rounded-xl text-sm text-red-400"></div>

    <button id="create-payment-btn" disabled
            class="w-full mt-5 bg-indigo-600 hover:bg-indigo-500 disabled:opacity-40 disabled:cursor-not-allowed text-white font-semibold py-3 rounded-xl transition-colors text-sm flex items-center justify-center gap-2">
      <span id="pay-btn-text">Pilih metode terlebih dahulu</span>
      <svg id="pay-spinner" class="hidden w-4 h-4 animate-spin" fill="none" viewBox="0 0 24 24">
        <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"/>
        <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8v8H4z"/>
      </svg>
    </button>
  </div>

  <%# ── STEP B: QR Code ─────────────────────────────────────────────────── %>
  <div id="step-qr" class="hidden bg-gray-900 border border-gray-800 rounded-2xl p-6 text-center">
    <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-yellow-500/10 border border-yellow-500/20 text-yellow-400 text-xs font-medium mb-5">
      <span class="w-1.5 h-1.5 rounded-full bg-yellow-400 animate-pulse"></span>
      Menunggu Pembayaran
    </div>

    <h2 class="text-lg font-semibold text-white mb-2">Scan QR Code</h2>
    <p class="text-sm text-gray-400 mb-6">Scan dengan aplikasi e-wallet atau mobile banking Anda</p>

    <div class="inline-block p-3 bg-white rounded-2xl mb-5">
      <img id="qr-image" src="" alt="QR Code" class="w-48 h-48 object-contain"/>
    </div>

    <p class="text-xl font-bold text-white mb-1">
      Rp <%= order.price.toLocaleString('id-ID') %>
    </p>

    <%# Countdown %>
    <div class="flex items-center justify-center gap-2 mt-3 mb-6">
      <svg class="w-4 h-4 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
      </svg>
      <p class="text-sm text-gray-400">Berlaku selama: <span id="countdown" class="text-white font-mono font-semibold">60:00</span></p>
    </div>

    <%# Polling status badge %>
    <div id="polling-status" class="flex items-center justify-center gap-2 text-xs text-gray-500">
      <svg class="w-3.5 h-3.5 animate-spin text-indigo-400" fill="none" viewBox="0 0 24 24">
        <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"/>
        <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8v8H4z"/>
      </svg>
      Memeriksa status pembayaran...
    </div>
  </div>

  <%# ── STEP C: Success ─────────────────────────────────────────────────── %>
  <div id="step-success" class="hidden bg-gray-900 border border-green-800 rounded-2xl p-8 text-center">
    <div class="w-16 h-16 bg-green-600/20 rounded-full flex items-center justify-center mx-auto mb-4">
      <svg class="w-8 h-8 text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
      </svg>
    </div>
    <h2 class="text-xl font-bold text-white mb-2">Pembayaran Berhasil! 🎉</h2>
    <p class="text-gray-400 text-sm mb-6">Pesanan Anda sudah masuk antrian pengerjaan. Kami akan segera memproses tugas Anda.</p>
    <a href="/dashboard"
       class="inline-block px-8 py-3 bg-indigo-600 hover:bg-indigo-500 text-white font-semibold rounded-xl transition-colors text-sm">
      Lihat Dashboard →
    </a>
  </div>
</section>

<script>
  const ORDER_ID = '<%= order.id %>';
  let selectedMethod = null;
  let pollInterval = null;
  let countdownInterval = null;

  // ── Load Methods ────────────────────────────────────────────────────────────
  async function loadMethods() {
    document.getElementById('methods-loading').classList.remove('hidden');
    document.getElementById('methods-grid').classList.add('hidden');
    document.getElementById('methods-error').classList.add('hidden');

    try {
      const res = await fetch('/api/payment/methods');
      const data = await res.json();
      if (!data.success) throw new Error();

      const grid = document.getElementById('methods-grid');
      grid.innerHTML = '';

      data.methods.filter(m => m.status === 'aktif').forEach(m => {
        const card = document.createElement('button');
        card.type = 'button';
        card.dataset.metode = m.metode.toLowerCase();
        card.innerHTML = `
          <div class="p-3 bg-gray-800 border-2 border-gray-700 rounded-xl hover:border-indigo-500
                      transition-all duration-200 text-center method-card group" data-metode="${m.metode.toLowerCase()}">
            ${m.img_url ? `<img src="${m.img_url}" alt="${m.name}" class="w-10 h-10 object-contain mx-auto mb-2 rounded-lg"/>` : `<div class="text-2xl mb-2">💳</div>`}
            <p class="text-xs font-medium text-gray-300 group-hover:text-white">${m.name}</p>
            <p class="text-xs text-gray-500 mt-0.5">${m.fee_persen > 0 ? m.fee_persen+'%' : 'Gratis'}</p>
          </div>`;
        card.addEventListener('click', () => selectMethod(m.metode.toLowerCase(), card));
        grid.appendChild(card);
      });

      document.getElementById('methods-loading').classList.add('hidden');
      grid.classList.remove('hidden');
    } catch {
      document.getElementById('methods-loading').classList.add('hidden');
      document.getElementById('methods-error').classList.remove('hidden');
    }
  }

  function selectMethod(metode, cardEl) {
    selectedMethod = metode;
    document.querySelectorAll('.method-card').forEach(c => {
      c.classList.remove('border-indigo-500', 'bg-indigo-600/10');
      c.classList.add('border-gray-700');
    });
    cardEl.querySelector('.method-card').classList.add('border-indigo-500', 'bg-indigo-600/10');
    cardEl.querySelector('.method-card').classList.remove('border-gray-700');

    const btn = document.getElementById('create-payment-btn');
    btn.disabled = false;
    document.getElementById('pay-btn-text').textContent = `Bayar dengan ${metode.toUpperCase()}`;
  }

  // ── Create Payment ──────────────────────────────────────────────────────────
  document.getElementById('create-payment-btn').addEventListener('click', async () => {
    if (!selectedMethod) return;
    const btn = document.getElementById('create-payment-btn');
    const spinner = document.getElementById('pay-spinner');
    const errEl = document.getElementById('method-error');

    btn.disabled = true;
    spinner.classList.remove('hidden');
    errEl.classList.add('hidden');

    try {
      const res = await fetch('/api/payment/create', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ orderId: ORDER_ID, metode: selectedMethod })
      });
      const data = await res.json();
      if (!data.success) throw new Error(data.error || 'Gagal membuat tagihan');

      showQR(data);
    } catch (err) {
      errEl.textContent = err.message;
      errEl.classList.remove('hidden');
      btn.disabled = false;
    } finally {
      spinner.classList.add('hidden');
    }
  });

  function showQR(data) {
    document.getElementById('step-method').classList.add('hidden');
    document.getElementById('step-qr').classList.remove('hidden');
    document.getElementById('qr-image').src = data.qr_image;
    startCountdown(data.expired_at);
    startPolling();
  }

  // ── Countdown ───────────────────────────────────────────────────────────────
  function startCountdown(expiredAt) {
    const expiry = new Date(expiredAt).getTime();
    countdownInterval = setInterval(() => {
      const remaining = expiry - Date.now();
      if (remaining <= 0) {
        clearInterval(countdownInterval);
        document.getElementById('countdown').textContent = '00:00';
        return;
      }
      const m = Math.floor(remaining / 60000);
      const s = Math.floor((remaining % 60000) / 1000);
      document.getElementById('countdown').textContent =
        String(m).padStart(2,'0') + ':' + String(s).padStart(2,'0');
    }, 1000);
  }

  // ── Status Polling ──────────────────────────────────────────────────────────
  function startPolling() {
    pollInterval = setInterval(async () => {
      try {
        const res = await fetch('/api/payment/status/' + ORDER_ID);
        const data = await res.json();
        if (data.payment_status === 'success') {
          clearInterval(pollInterval);
          clearInterval(countdownInterval);
          document.getElementById('step-qr').classList.add('hidden');
          document.getElementById('step-success').classList.remove('hidden');
          setTimeout(() => window.location.href = '/dashboard?paid=1', 2500);
        }
      } catch { /* silent fail, retry next interval */ }
    }, 5000);
  }

  // Init
  loadMethods();
</script>
