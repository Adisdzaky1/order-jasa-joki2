<%# views/admin/pesanan.ejs %>
<% title = 'Semua Pesanan' %>

<%
function statusBadge(status, queueNumber) {
  const map = {
    menunggu_pembayaran: ['bg-yellow-500/20 text-yellow-400 border-yellow-500/30', 'Menunggu Bayar'],
    antrian:             ['bg-blue-500/20 text-blue-400 border-blue-500/30',       'Antrian'],
    dikerjakan:          ['bg-orange-500/20 text-orange-400 border-orange-500/30', 'Dikerjakan'],
    selesai:             ['bg-green-500/20 text-green-400 border-green-500/30',    'Selesai'],
  };
  const [cls, label] = map[status] || ['bg-gray-500/20 text-gray-400 border-gray-500/30', status];
  const extra = status === 'antrian' && queueNumber ? ` #${queueNumber}` : '';
  return `<span class="px-2.5 py-1 rounded-full text-xs font-semibold border ${cls}">${label}${extra}</span>`;
}
%>

<%# ── Header ─────────────────────────────────────────────────────────────── %>
<div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4 mb-8">
  <div>
    <h1 class="text-2xl font-bold text-white">Semua Pesanan</h1>
    <p class="text-gray-400 text-sm mt-1"><%= orders.length %> total pesanan</p>
  </div>
</div>

<%# ── Filter & Search Bar ─────────────────────────────────────────────────── %>
<div class="flex flex-col sm:flex-row gap-3 mb-6">
  <%# Search %>
  <div class="relative flex-1">
    <svg class="absolute left-3.5 top-1/2 -translate-y-1/2 w-4 h-4 text-gray-500"
         fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
            d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
    </svg>
    <input id="search" type="text" placeholder="Cari ID, email, atau nama layanan..."
           class="w-full bg-gray-800 border border-gray-700 rounded-xl pl-10 pr-4 py-2.5
                  text-gray-100 focus:outline-none focus:border-indigo-500 focus:ring-1
                  focus:ring-indigo-500 transition-colors text-sm"/>
  </div>

  <%# Status Filter %>
  <select id="filter-status"
          class="bg-gray-800 border border-gray-700 rounded-xl px-4 py-2.5 text-gray-300
                 focus:outline-none focus:border-indigo-500 transition-colors text-sm min-w-[180px]">
    <option value="">Semua Status</option>
    <option value="menunggu_pembayaran">Menunggu Pembayaran</option>
    <option value="antrian">Antrian</option>
    <option value="dikerjakan">Dikerjakan</option>
    <option value="selesai">Selesai</option>
  </select>
</div>

<%# ── Table ──────────────────────────────────────────────────────────────── %>
<div class="bg-gray-900 border border-gray-800 rounded-2xl overflow-hidden">
  <% if (orders.length === 0) { %>
    <div class="text-center py-16 text-gray-500 text-sm">Belum ada pesanan masuk.</div>
  <% } else { %>

    <%# Desktop %>
    <div class="hidden md:block overflow-x-auto">
      <table class="w-full text-sm">
        <thead>
          <tr class="border-b border-gray-800">
            <% ['ID', 'User', 'Layanan', 'Harga', 'Status', 'Tanggal', ''].forEach(h => { %>
              <th class="text-left text-xs font-semibold text-gray-500 uppercase tracking-wider px-5 py-3"><%= h %></th>
            <% }) %>
          </tr>
        </thead>
        <tbody id="orders-tbody" class="divide-y divide-gray-800">
          <% orders.forEach(order => { %>
            <tr class="order-row hover:bg-gray-800/40 transition-colors"
                data-id="<%= order.id.toLowerCase() %>"
                data-email="<%= (order.user_email || '').toLowerCase() %>"
                data-service="<%= (order.service_name || '').toLowerCase() %>"
                data-status="<%= order.status %>">

              <td class="px-5 py-3.5">
                <span class="font-mono text-xs text-gray-400 bg-gray-800 px-2 py-1 rounded-lg">
                  <%= order.id.slice(0,8).toUpperCase() %>
                </span>
              </td>
              <td class="px-5 py-3.5">
                <div>
                  <p class="text-gray-200 text-xs font-medium truncate max-w-[160px]"><%= order.user_name || '—' %></p>
                  <p class="text-gray-500 text-xs truncate max-w-[160px]"><%= order.user_email %></p>
                </div>
              </td>
              <td class="px-5 py-3.5 text-gray-200 max-w-[180px] truncate"><%= order.service_name %></td>
              <td class="px-5 py-3.5 text-indigo-400 font-semibold whitespace-nowrap">
                Rp <%= order.price.toLocaleString('id-ID') %>
              </td>
              <td class="px-5 py-3.5"><%- statusBadge(order.status, order.queue_number) %></td>
              <td class="px-5 py-3.5 text-gray-500 whitespace-nowrap text-xs">
                <%= new Date(order.created_at).toLocaleDateString('id-ID', {day:'2-digit',month:'short',year:'numeric'}) %>
              </td>
              <td class="px-5 py-3.5">
                <a href="/admin/pesanan/<%= order.id %>"
                   class="inline-flex items-center gap-1 text-xs text-indigo-400 hover:text-white hover:bg-indigo-600
                          px-3 py-1.5 rounded-lg transition-all font-medium">
                  Detail
                  <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                  </svg>
                </a>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>

    <%# Mobile Cards %>
    <div class="md:hidden divide-y divide-gray-800" id="mobile-orders">
      <% orders.forEach(order => { %>
        <div class="mobile-order-row p-4 hover:bg-gray-800/30 transition-colors"
             data-id="<%= order.id.toLowerCase() %>"
             data-email="<%= (order.user_email || '').toLowerCase() %>"
             data-service="<%= (order.service_name || '').toLowerCase() %>"
             data-status="<%= order.status %>">
          <div class="flex items-start justify-between gap-3 mb-2">
            <div class="min-w-0 flex-1">
              <p class="text-sm font-medium text-white truncate"><%= order.service_name %></p>
              <p class="text-xs text-gray-500 mt-0.5"><%= order.user_email %></p>
            </div>
            <%- statusBadge(order.status, order.queue_number) %>
          </div>
          <div class="flex items-center justify-between mt-2">
            <div>
              <p class="text-indigo-400 text-sm font-bold">Rp <%= order.price.toLocaleString('id-ID') %></p>
              <p class="text-gray-600 text-xs mt-0.5">
                <%= new Date(order.created_at).toLocaleDateString('id-ID') %>
              </p>
            </div>
            <a href="/admin/pesanan/<%= order.id %>"
               class="text-xs text-indigo-400 hover:text-indigo-300 font-medium">Detail →</a>
          </div>
        </div>
      <% }) %>
    </div>

    <%# Empty search state %>
    <div id="empty-search" class="hidden text-center py-12 text-gray-500 text-sm">
      Tidak ada pesanan yang cocok dengan pencarian
    </div>
  <% } %>
</div>

<script>
  const searchEl = document.getElementById('search');
  const statusEl = document.getElementById('filter-status');
  const desktopRows = document.querySelectorAll('.order-row');
  const mobileRows = document.querySelectorAll('.mobile-order-row');
  const emptyEl = document.getElementById('empty-search');

  function filter() {
    const q = searchEl.value.toLowerCase().trim();
    const s = statusEl.value;
    let visible = 0;

    function checkRow(row) {
      const matchQ = !q ||
        row.dataset.id.includes(q) ||
        row.dataset.email.includes(q) ||
        row.dataset.service.includes(q);
      const matchS = !s || row.dataset.status === s;
      const show = matchQ && matchS;
      row.style.display = show ? '' : 'none';
      if (show) visible++;
    }

    desktopRows.forEach(checkRow);
    mobileRows.forEach(checkRow);
    if (emptyEl) emptyEl.classList.toggle('hidden', visible > 0);
  }

  searchEl?.addEventListener('input', filter);
  statusEl?.addEventListener('change', filter);
</script>
