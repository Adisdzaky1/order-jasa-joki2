<%# views/admin/dashboard.ejs %>
<% title = 'Admin Dashboard' %>

<%
function statusBadge(status) {
  const map = {
    menunggu_pembayaran: ['bg-yellow-500/20 text-yellow-400 border-yellow-500/30', '⏳ Menunggu Bayar'],
    antrian:             ['bg-blue-500/20 text-blue-400 border-blue-500/30',       '🔵 Antrian'],
    dikerjakan:          ['bg-orange-500/20 text-orange-400 border-orange-500/30', '🟠 Dikerjakan'],
    selesai:             ['bg-green-500/20 text-green-400 border-green-500/30',    '✅ Selesai'],
  };
  const [cls, label] = map[status] || ['bg-gray-500/20 text-gray-400 border-gray-500/30', status];
  return `<span class="px-2.5 py-1 rounded-full text-xs font-semibold border ${cls}">${label}</span>`;
}
%>

<%# ── Page Header ─────────────────────────────────────────────────────────── %>
<div class="mb-8">
  <h1 class="text-2xl font-bold text-white">Dashboard</h1>
  <p class="text-gray-400 text-sm mt-1">Ringkasan aktivitas JasaTugas.id</p>
</div>

<%# ── Stats Cards ─────────────────────────────────────────────────────────── %>
<div class="grid grid-cols-2 xl:grid-cols-4 gap-4 mb-8">
  <% [
    { label:'Total Pesanan',  value: stats.total,     icon:'📋', color:'indigo',  sub:'semua waktu' },
    { label:'Menunggu Bayar', value: stats.menunggu,  icon:'⏳', color:'yellow',  sub:'perlu tindakan' },
    { label:'Dikerjakan',     value: stats.dikerjakan,icon:'⚡', color:'orange',  sub:'sedang berjalan' },
    { label:'Selesai',        value: stats.selesai,   icon:'✅', color:'green',   sub:'terselesaikan' },
  ].forEach(s => { %>
    <div class="bg-gray-900 border border-gray-800 rounded-2xl p-5 hover:border-gray-700 transition-colors">
      <div class="flex items-start justify-between mb-3">
        <span class="text-2xl"><%= s.icon %></span>
        <span class="text-xs text-gray-600 bg-gray-800 px-2 py-0.5 rounded-full"><%= s.sub %></span>
      </div>
      <p class="text-3xl font-extrabold text-white"><%= s.value %></p>
      <p class="text-sm text-gray-400 mt-1"><%= s.label %></p>
    </div>
  <% }) %>
</div>

<%# ── Chart + Recent Orders ─────────────────────────────────────────────────── %>
<div class="grid grid-cols-1 xl:grid-cols-5 gap-6">

  <%# Chart %>
  <div class="xl:col-span-2 bg-gray-900 border border-gray-800 rounded-2xl p-6">
    <h2 class="text-base font-semibold text-white mb-5">Distribusi Status</h2>
    <div class="relative">
      <canvas id="statusChart" height="240"></canvas>
    </div>
    <%# Legend manual %>
    <div class="grid grid-cols-2 gap-2 mt-5">
      <% [
        ['Menunggu Bayar', '#eab308', stats.menunggu],
        ['Antrian',        '#3b82f6', stats.antrian],
        ['Dikerjakan',     '#f97316', stats.dikerjakan],
        ['Selesai',        '#22c55e', stats.selesai],
      ].forEach(([label, color, val]) => { %>
        <div class="flex items-center gap-2">
          <span class="w-3 h-3 rounded-full shrink-0" style="background:<%= color %>"></span>
          <span class="text-xs text-gray-400 truncate"><%= label %></span>
          <span class="text-xs text-white font-semibold ml-auto"><%= val %></span>
        </div>
      <% }) %>
    </div>
  </div>

  <%# Recent Orders Table %>
  <div class="xl:col-span-3 bg-gray-900 border border-gray-800 rounded-2xl overflow-hidden">
    <div class="px-6 py-4 border-b border-gray-800 flex items-center justify-between">
      <h2 class="text-base font-semibold text-white">5 Pesanan Terbaru</h2>
      <a href="/admin/pesanan" class="text-xs text-indigo-400 hover:text-indigo-300 transition-colors font-medium">
        Lihat Semua →
      </a>
    </div>

    <% if (recentOrders.length === 0) { %>
      <div class="text-center py-12 text-gray-500 text-sm">Belum ada pesanan</div>
    <% } else { %>
      <div class="divide-y divide-gray-800">
        <% recentOrders.forEach(order => { %>
          <div class="px-6 py-4 hover:bg-gray-800/40 transition-colors flex items-center justify-between gap-4">
            <div class="min-w-0 flex-1">
              <p class="text-sm font-medium text-white truncate"><%= order.service_name %></p>
              <p class="text-xs text-gray-500 mt-0.5 truncate">
                <%= order.user_email %> ·
                <%= new Date(order.created_at).toLocaleDateString('id-ID', {day:'numeric',month:'short'}) %>
              </p>
            </div>
            <div class="flex items-center gap-3 shrink-0">
              <%- statusBadge(order.status) %>
              <a href="/admin/pesanan/<%= order.id %>"
                 class="text-xs text-indigo-400 hover:text-indigo-300 font-medium transition-colors">
                Detail →
              </a>
            </div>
          </div>
        <% }) %>
      </div>
    <% } %>
  </div>
</div>

<%# Quick action bar %>
<div class="mt-6 bg-indigo-600/10 border border-indigo-500/20 rounded-2xl p-5 flex flex-col sm:flex-row items-center justify-between gap-4">
  <div>
    <p class="text-white font-semibold text-sm">Ada <%= stats.antrian %> pesanan dalam antrian pengerjaan</p>
    <p class="text-indigo-300 text-xs mt-0.5">Segera proses agar pelanggan tidak menunggu terlalu lama</p>
  </div>
  <a href="/admin/pesanan"
     class="shrink-0 px-5 py-2.5 bg-indigo-600 hover:bg-indigo-500 text-white font-semibold rounded-xl text-sm transition-colors">
    Kelola Pesanan
  </a>
</div>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script>
  const ctx = document.getElementById('statusChart').getContext('2d');
  new Chart(ctx, {
    type: 'bar',
    data: {
      labels: ['Menunggu', 'Antrian', 'Dikerjakan', 'Selesai'],
      datasets: [{
        data: [<%= stats.menunggu %>, <%= stats.antrian %>, <%= stats.dikerjakan %>, <%= stats.selesai %>],
        backgroundColor: ['rgba(234,179,8,0.7)', 'rgba(59,130,246,0.7)', 'rgba(249,115,22,0.7)', 'rgba(34,197,94,0.7)'],
        borderColor:     ['#eab308', '#3b82f6', '#f97316', '#22c55e'],
        borderWidth: 1.5,
        borderRadius: 8,
        borderSkipped: false,
      }]
    },
    options: {
      responsive: true,
      plugins: { legend: { display: false } },
      scales: {
        x: {
          grid: { color: 'rgba(255,255,255,0.05)' },
          ticks: { color: '#9ca3af', font: { size: 11 } }
        },
        y: {
          grid: { color: 'rgba(255,255,255,0.05)' },
          ticks: { color: '#9ca3af', font: { size: 11 }, stepSize: 1 },
          beginAtZero: true
        }
      }
    }
  });
</script>
