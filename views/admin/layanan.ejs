<%# views/admin/layanan.ejs %>
<% title = 'Kelola Layanan' %>

<%# ── Header ─────────────────────────────────────────────────────────────── %>
<div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4 mb-8">
  <div>
    <h1 class="text-2xl font-bold text-white">Kelola Layanan</h1>
    <p class="text-gray-400 text-sm mt-1"><%= services.length %> layanan terdaftar</p>
  </div>
  <button onclick="openModal('add')"
          class="inline-flex items-center gap-2 px-5 py-2.5 bg-indigo-600 hover:bg-indigo-500
                 text-white font-semibold rounded-xl transition-colors text-sm">
    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
    </svg>
    Tambah Layanan
  </button>
</div>

<%# ── Grid Layanan ───────────────────────────────────────────────────────── %>
<% if (services.length === 0) { %>
  <div class="text-center py-16 bg-gray-900 border border-gray-800 rounded-2xl">
    <div class="text-5xl mb-4">📭</div>
    <p class="text-white font-semibold mb-2">Belum ada layanan</p>
    <p class="text-gray-400 text-sm mb-5">Klik "Tambah Layanan" untuk menambahkan layanan baru</p>
    <button onclick="openModal('add')"
            class="px-5 py-2.5 bg-indigo-600 hover:bg-indigo-500 text-white font-semibold rounded-xl text-sm transition-colors">
      + Tambah Layanan
    </button>
  </div>
<% } else { %>
  <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-5">
    <% services.forEach(sv => { %>
      <div class="bg-gray-900 border border-gray-800 rounded-2xl p-5 hover:border-gray-700 transition-colors flex flex-col">

        <div class="flex items-start justify-between mb-3">
          <div class="flex items-center gap-3">
            <span class="text-3xl"><%= sv.icon %></span>
            <div>
              <h3 class="font-semibold text-white text-sm leading-tight"><%= sv.name %></h3>
              <span class="text-xs text-gray-500 bg-gray-800 px-2 py-0.5 rounded-full mt-1 inline-block"><%= sv.category %></span>
            </div>
          </div>
          <div class="flex gap-1.5 shrink-0">
            <button onclick="openModal('edit', <%- JSON.stringify(sv) %>)"
                    class="p-1.5 text-gray-400 hover:text-indigo-400 hover:bg-indigo-600/10 rounded-lg transition-colors">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                      d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
              </svg>
            </button>
            <button onclick="confirmDelete('<%= sv.id %>', '<%= sv.name.replace(/'/g, '') %>')"
                    class="p-1.5 text-gray-400 hover:text-red-400 hover:bg-red-600/10 rounded-lg transition-colors">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                      d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
              </svg>
            </button>
          </div>
        </div>

        <p class="text-gray-400 text-xs leading-relaxed mb-3 flex-1"><%= sv.description %></p>

        <div class="flex items-center justify-between pt-3 border-t border-gray-800">
          <span class="text-indigo-400 font-bold text-sm">Rp <%= sv.price.toLocaleString('id-ID') %></span>
          <span class="text-xs text-gray-500">⏱ <%= sv.estimasi %></span>
        </div>

        <% if (sv.features && sv.features.length > 0) { %>
          <div class="mt-3 pt-3 border-t border-gray-800 space-y-1">
            <% sv.features.slice(0,3).forEach(f => { %>
              <p class="text-xs text-gray-500 flex items-center gap-1.5">
                <svg class="w-3 h-3 text-green-400 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/>
                </svg>
                <%= f %>
              </p>
            <% }) %>
            <% if (sv.features.length > 3) { %>
              <p class="text-xs text-gray-600">+<%= sv.features.length - 3 %> lainnya</p>
            <% } %>
          </div>
        <% } %>
      </div>
    <% }) %>
  </div>
<% } %>

<%# ── Modal Add / Edit ───────────────────────────────────────────────────── %>
<div id="svc-modal" class="fixed inset-0 z-50 hidden">
  <div class="absolute inset-0 bg-black/70 backdrop-blur-sm" onclick="closeModal()"></div>
  <div class="absolute inset-0 flex items-center justify-center p-4">
    <div class="relative bg-gray-900 border border-gray-800 rounded-2xl w-full max-w-lg max-h-[90vh] overflow-y-auto">

      <div class="flex items-center justify-between px-6 py-4 border-b border-gray-800 sticky top-0 bg-gray-900 rounded-t-2xl">
        <h3 id="modal-title" class="text-base font-semibold text-white">Tambah Layanan</h3>
        <button onclick="closeModal()" class="text-gray-500 hover:text-white transition-colors">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
          </svg>
        </button>
      </div>

      <form id="svc-form" method="POST" action="/admin/layanan/add" class="p-6 space-y-4">
        <input type="hidden" id="svc-id" name="_svcId" value=""/>

        <div class="grid grid-cols-2 gap-4">
          <div class="col-span-2">
            <label class="block text-xs font-medium text-gray-400 mb-1.5">Nama Layanan *</label>
            <input type="text" id="f-name" name="name" required placeholder="Jasa Skripsi Lengkap"
                   class="w-full bg-gray-800 border border-gray-700 rounded-xl px-3.5 py-2.5 text-gray-100 text-sm
                          focus:outline-none focus:border-indigo-500 transition-colors"/>
          </div>
          <div>
            <label class="block text-xs font-medium text-gray-400 mb-1.5">Icon (emoji) *</label>
            <input type="text" id="f-icon" name="icon" placeholder="📚" maxlength="4"
                   class="w-full bg-gray-800 border border-gray-700 rounded-xl px-3.5 py-2.5 text-gray-100 text-sm
                          focus:outline-none focus:border-indigo-500 transition-colors text-center text-xl"/>
          </div>
          <div>
            <label class="block text-xs font-medium text-gray-400 mb-1.5">Kategori</label>
            <select id="f-category" name="category"
                    class="w-full bg-gray-800 border border-gray-700 rounded-xl px-3.5 py-2.5 text-gray-100 text-sm
                           focus:outline-none focus:border-indigo-500 transition-colors">
              <option value="akademik">Akademik</option>
              <option value="coding">Coding</option>
              <option value="desain">Desain</option>
              <option value="lainnya">Lainnya</option>
            </select>
          </div>
          <div>
            <label class="block text-xs font-medium text-gray-400 mb-1.5">Harga (Rp) *</label>
            <input type="number" id="f-price" name="price" required min="1000" placeholder="150000"
                   class="w-full bg-gray-800 border border-gray-700 rounded-xl px-3.5 py-2.5 text-gray-100 text-sm
                          focus:outline-none focus:border-indigo-500 transition-colors"/>
          </div>
          <div>
            <label class="block text-xs font-medium text-gray-400 mb-1.5">Estimasi Pengerjaan</label>
            <input type="text" id="f-estimasi" name="estimasi" placeholder="3-7 hari"
                   class="w-full bg-gray-800 border border-gray-700 rounded-xl px-3.5 py-2.5 text-gray-100 text-sm
                          focus:outline-none focus:border-indigo-500 transition-colors"/>
          </div>
          <div class="col-span-2">
            <label class="block text-xs font-medium text-gray-400 mb-1.5">Deskripsi</label>
            <textarea id="f-description" name="description" rows="3" placeholder="Deskripsi singkat layanan..."
                      class="w-full bg-gray-800 border border-gray-700 rounded-xl px-3.5 py-2.5 text-gray-100 text-sm
                             focus:outline-none focus:border-indigo-500 transition-colors resize-none"></textarea>
          </div>
          <div class="col-span-2">
            <label class="block text-xs font-medium text-gray-400 mb-1.5">
              Fitur / Keunggulan
              <span class="text-gray-600 font-normal">(satu per baris)</span>
            </label>
            <textarea id="f-features" name="features" rows="4"
                      placeholder="Revisi 3x gratis&#10;Plagiarisme < 20%&#10;Format Word + PDF"
                      class="w-full bg-gray-800 border border-gray-700 rounded-xl px-3.5 py-2.5 text-gray-100 text-sm
                             focus:outline-none focus:border-indigo-500 transition-colors resize-none"></textarea>
          </div>
        </div>

        <button type="submit"
                class="w-full bg-indigo-600 hover:bg-indigo-500 text-white font-semibold py-3 rounded-xl
                       transition-colors text-sm mt-2">
          Simpan Layanan
        </button>
      </form>
    </div>
  </div>
</div>

<%# Form delete (hidden, submit via JS) %>
<form id="delete-form" method="POST" action="" class="hidden">
  <input type="hidden" name="_method" value="DELETE"/>
</form>

<script>
  function openModal(mode, svc) {
    const modal   = document.getElementById('svc-modal');
    const form    = document.getElementById('svc-form');
    const titleEl = document.getElementById('modal-title');

    // Reset
    form.reset();
    document.getElementById('svc-id').value = '';

    if (mode === 'edit' && svc) {
      titleEl.textContent = 'Edit Layanan';
      form.action = `/admin/layanan/${svc.id}/edit`;

      document.getElementById('f-name').value        = svc.name        || '';
      document.getElementById('f-icon').value        = svc.icon        || '';
      document.getElementById('f-category').value    = svc.category    || 'lainnya';
      document.getElementById('f-price').value       = svc.price       || '';
      document.getElementById('f-estimasi').value    = svc.estimasi    || '';
      document.getElementById('f-description').value = svc.description || '';
      document.getElementById('f-features').value    = (svc.features || []).join('\n');
    } else {
      titleEl.textContent = 'Tambah Layanan Baru';
      form.action = '/admin/layanan/add';
    }

    modal.classList.remove('hidden');
    document.body.style.overflow = 'hidden';
  }

  function closeModal() {
    document.getElementById('svc-modal').classList.add('hidden');
    document.body.style.overflow = '';
  }

  function confirmDelete(id, name) {
    if (!confirm(`Hapus layanan "${name}"?\nTindakan ini tidak dapat dibatalkan.`)) return;
    const form = document.getElementById('delete-form');
    form.action = `/admin/layanan/${id}/delete`;
    form.submit();
  }

  document.addEventListener('keydown', e => { if (e.key === 'Escape') closeModal(); });
</script>
