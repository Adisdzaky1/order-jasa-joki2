<%# views/admin/pesanan-detail.ejs %>
<% layout('layouts/admin') %>
<% title = 'Detail Pesanan #' + order.id.slice(0,8).toUpperCase() %>

<%
const STATUS_CONFIG = {
  menunggu_pembayaran: { cls:'bg-yellow-500/20 text-yellow-400 border-yellow-500/30', label:'Menunggu Pembayaran' },
  antrian:             { cls:'bg-blue-500/20 text-blue-400 border-blue-500/30',       label:'Antrian' },
  dikerjakan:          { cls:'bg-orange-500/20 text-orange-400 border-orange-500/30', label:'Dikerjakan' },
  selesai:             { cls:'bg-green-500/20 text-green-400 border-green-500/30',    label:'Selesai' },
};
const sc = STATUS_CONFIG[order.status] || { cls:'bg-gray-500/20 text-gray-400 border-gray-500/30', label: order.status };
%>

<%# ── Back + Header ──────────────────────────────────────────────────────── %>
<div class="mb-6">
  <a href="/admin/pesanan" class="inline-flex items-center gap-2 text-sm text-gray-400 hover:text-white transition-colors mb-4">
    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
    </svg>
    Kembali ke Semua Pesanan
  </a>

  <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-3">
    <div>
      <div class="flex items-center gap-3">
        <h1 class="text-2xl font-bold text-white">
          Pesanan <span class="font-mono text-indigo-400"><%= order.id.slice(0,8).toUpperCase() %></span>
        </h1>
        <span class="px-2.5 py-1 rounded-full text-xs font-semibold border <%= sc.cls %>"><%= sc.label %><% if(order.status==='antrian' && order.queue_number){ %> #<%= order.queue_number %><% } %></span>
      </div>
      <p class="text-gray-500 text-sm mt-1">
        Dibuat <%= new Date(order.created_at).toLocaleString('id-ID', {day:'numeric',month:'long',year:'numeric',hour:'2-digit',minute:'2-digit'}) %>
      </p>
    </div>
  </div>
</div>

<%# ── 2-Column Layout ─────────────────────────────────────────────────────── %>
<div class="grid grid-cols-1 xl:grid-cols-5 gap-6">

  <%# ─── KOLOM KIRI: Info Pesanan (3/5) ──────────────────────────────────── %>
  <div class="xl:col-span-3 space-y-5">

    <%# Info Dasar %>
    <div class="bg-gray-900 border border-gray-800 rounded-2xl p-6">
      <h2 class="text-sm font-semibold text-gray-400 uppercase tracking-wider mb-4">Info Pesanan</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <div>
          <p class="text-xs text-gray-500 mb-1">ID Pesanan</p>
          <p class="text-white font-mono text-sm bg-gray-800 px-3 py-2 rounded-lg break-all"><%= order.id %></p>
        </div>
        <div>
          <p class="text-xs text-gray-500 mb-1">Layanan</p>
          <p class="text-white font-medium text-sm"><%= order.service_name %></p>
        </div>
        <div>
          <p class="text-xs text-gray-500 mb-1">Harga</p>
          <p class="text-indigo-400 font-bold text-lg">Rp <%= order.price.toLocaleString('id-ID') %></p>
        </div>
        <div>
          <p class="text-xs text-gray-500 mb-1">Metode Bayar</p>
          <p class="text-white text-sm uppercase"><%= order.payment_method || '—' %></p>
        </div>
        <div>
          <p class="text-xs text-gray-500 mb-1">Status Pembayaran</p>
          <% if (order.payment_status === 'success') { %>
            <span class="px-2.5 py-1 rounded-full text-xs font-semibold bg-green-500/20 text-green-400 border border-green-500/30">✅ Lunas</span>
          <% } else { %>
            <span class="px-2.5 py-1 rounded-full text-xs font-semibold bg-yellow-500/20 text-yellow-400 border border-yellow-500/30">⏳ Belum Bayar</span>
          <% } %>
        </div>
        <div>
          <p class="text-xs text-gray-500 mb-1">Terakhir Update</p>
          <p class="text-gray-300 text-sm">
            <%= new Date(order.updated_at).toLocaleDateString('id-ID', {day:'numeric',month:'short',year:'numeric'}) %>
          </p>
        </div>
      </div>
    </div>

    <%# Info User %>
    <div class="bg-gray-900 border border-gray-800 rounded-2xl p-6">
      <h2 class="text-sm font-semibold text-gray-400 uppercase tracking-wider mb-4">Info Pelanggan</h2>
      <div class="flex items-center gap-4">
        <div class="w-12 h-12 rounded-full bg-indigo-600/20 flex items-center justify-center text-indigo-400 font-bold text-lg shrink-0">
          <%= (order.user_name || '?').charAt(0).toUpperCase() %>
        </div>
        <div>
          <p class="text-white font-semibold"><%= order.user_name || '—' %></p>
          <p class="text-gray-400 text-sm"><%= order.user_email %></p>
          <p class="text-gray-600 text-xs font-mono mt-0.5"><%= order.user_id %></p>
        </div>
      </div>
    </div>

    <%# Detail Tugas %>
    <div class="bg-gray-900 border border-gray-800 rounded-2xl p-6">
      <h2 class="text-sm font-semibold text-gray-400 uppercase tracking-wider mb-4">Detail Tugas</h2>
      <div class="space-y-4">
        <div>
          <p class="text-xs text-gray-500 mb-1.5">Judul Tugas</p>
          <p class="text-white font-medium"><%= order.title %></p>
        </div>
        <div>
          <p class="text-xs text-gray-500 mb-1.5">Deskripsi</p>
          <p class="text-gray-300 text-sm leading-relaxed whitespace-pre-wrap bg-gray-800 rounded-xl p-4"><%= order.description %></p>
        </div>
      </div>
    </div>

    <%# Lampiran User %>
    <% if (order.attachment_file) { %>
      <div class="bg-gray-900 border border-gray-800 rounded-2xl p-6">
        <h2 class="text-sm font-semibold text-gray-400 uppercase tracking-wider mb-4">Lampiran Pelanggan</h2>

        <% const isImage = order.attachment_type && order.attachment_type.startsWith('image/'); %>
        <% if (isImage) { %>
          <div class="rounded-xl overflow-hidden border border-gray-700 mb-3 max-w-sm">
            <img src="data:<%= order.attachment_type %>;base64,<%= order.attachment_file %>"
                 alt="Lampiran" class="w-full h-auto object-contain max-h-64"/>
          </div>
        <% } %>

        <div class="flex items-center gap-3 p-3.5 bg-gray-800 rounded-xl border border-gray-700">
          <span class="text-2xl">
            <%= order.attachment_type === 'application/pdf' ? '📄' : isImage ? '🖼️' : '📝' %>
          </span>
          <div class="flex-1 min-w-0">
            <p class="text-sm text-white font-medium truncate"><%= order.attachment_name %></p>
            <p class="text-xs text-gray-500"><%= order.attachment_type %></p>
          </div>
          <a href="#"
             onclick="downloadBase64('<%= order.attachment_type %>','<%= order.attachment_file %>','<%= order.attachment_name %>',event)"
             class="shrink-0 px-3 py-1.5 bg-indigo-600 hover:bg-indigo-500 text-white text-xs font-semibold rounded-lg transition-colors">
            Download
          </a>
        </div>
      </div>
    <% } %>

    <%# Hasil Kerja (sudah selesai) %>
    <% if (order.result_file) { %>
      <div class="bg-gray-900 border border-green-800 rounded-2xl p-6">
        <h2 class="text-sm font-semibold text-green-400 uppercase tracking-wider mb-4">✅ File Hasil Pengerjaan</h2>
        <div class="flex items-center gap-3 p-3.5 bg-gray-800 rounded-xl border border-gray-700">
          <span class="text-2xl">📦</span>
          <div class="flex-1 min-w-0">
            <p class="text-sm text-white font-medium truncate"><%= order.result_filename %></p>
            <p class="text-xs text-gray-500"><%= order.result_filetype %></p>
          </div>
          <a href="#"
             onclick="downloadBase64('<%= order.result_filetype %>','<%= order.result_file %>','<%= order.result_filename %>',event)"
             class="shrink-0 px-3 py-1.5 bg-green-600 hover:bg-green-500 text-white text-xs font-semibold rounded-lg transition-colors">
            Download
          </a>
        </div>
      </div>
    <% } %>
  </div>

  <%# ─── KOLOM KANAN: Panel Kelola (2/5) ─────────────────────────────────── %>
  <div class="xl:col-span-2">
    <div class="bg-gray-900 border border-gray-800 rounded-2xl p-6 sticky top-6">
      <h2 class="text-sm font-semibold text-gray-400 uppercase tracking-wider mb-5">Panel Kelola</h2>

      <form id="update-form" action="/admin/orders/<%= order.id %>/update"
            method="POST" enctype="multipart/form-data" class="space-y-5">

        <%# Status Select %>
        <div>
          <label class="block text-sm font-medium text-gray-300 mb-2">Ubah Status</label>
          <select name="status" id="status-select"
                  class="w-full bg-gray-800 border border-gray-700 rounded-xl px-4 py-3 text-gray-100
                         focus:outline-none focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500
                         transition-colors text-sm">
            <option value="menunggu_pembayaran" <%= order.status === 'menunggu_pembayaran' ? 'selected' : '' %>>
              ⏳ Menunggu Pembayaran
            </option>
            <option value="antrian" <%= order.status === 'antrian' ? 'selected' : '' %>>
              🔵 Antrian (nomor urut otomatis)
            </option>
            <option value="dikerjakan" <%= order.status === 'dikerjakan' ? 'selected' : '' %>>
              🟠 Sedang Dikerjakan
            </option>
            <option value="selesai" <%= order.status === 'selesai' ? 'selected' : '' %>>
              ✅ Selesai
            </option>
          </select>
        </div>

        <%# Upload File Hasil (hanya muncul jika pilih "selesai") %>
        <div id="result-upload-wrapper"
             class="<%= order.status === 'selesai' ? '' : 'hidden' %> space-y-2">
          <label class="block text-sm font-medium text-gray-300">
            Upload File Hasil
            <span id="file-required-badge" class="ml-1 text-xs text-red-400">* wajib jika selesai</span>
          </label>
          <div id="result-drop"
               class="border-2 border-dashed border-gray-700 rounded-xl p-5 text-center cursor-pointer
                      hover:border-indigo-500 transition-colors group">
            <input type="file" name="result_file" id="result-file"
                   accept=".jpg,.jpeg,.png,.pdf,.docx" class="hidden"/>
            <div id="result-placeholder">
              <svg class="w-7 h-7 text-gray-600 mx-auto mb-2 group-hover:text-indigo-400 transition-colors"
                   fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                      d="M7 16a4 4 0 01-.88-7.903A5 5 0 1115.9 6L16 6a5 5 0 011 9.9M15 13l-3-3m0 0l-3 3m3-3v12"/>
              </svg>
              <p class="text-xs text-gray-400">Klik atau drag file hasil</p>
              <p class="text-xs text-gray-600 mt-0.5">JPG, PNG, PDF, DOCX — maks. 2MB</p>
            </div>
            <div id="result-preview" class="hidden flex items-center justify-center gap-2">
              <span id="r-icon" class="text-xl">📄</span>
              <span id="r-name" class="text-sm text-white font-medium"></span>
              <button type="button" id="r-remove" class="text-gray-500 hover:text-red-400 ml-1">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
                </svg>
              </button>
            </div>
          </div>
          <% if (order.result_file) { %>
            <p class="text-xs text-green-400">✅ File hasil sudah ada. Upload baru untuk mengganti.</p>
          <% } %>
        </div>

        <%# Catatan %>
        <div id="form-err" class="hidden p-3 bg-red-950 border border-red-800 rounded-xl text-xs text-red-400"></div>

        <button type="submit" id="save-btn"
                class="w-full bg-indigo-600 hover:bg-indigo-500 text-white font-semibold
                       py-3 rounded-xl transition-colors text-sm flex items-center justify-center gap-2">
          <span id="save-text">Simpan Perubahan</span>
          <svg id="save-spin" class="hidden w-4 h-4 animate-spin" fill="none" viewBox="0 0 24 24">
            <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"/>
            <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8v8H4z"/>
          </svg>
        </button>
      </form>

      <%# Status History %>
      <div class="mt-6 pt-6 border-t border-gray-800">
        <h3 class="text-xs font-semibold text-gray-500 uppercase tracking-wider mb-3">Status Saat Ini</h3>
        <div class="flex flex-col gap-2">
          <% ['menunggu_pembayaran','antrian','dikerjakan','selesai'].forEach((s, i) => {
            const labels = ['Menunggu Pembayaran','Antrian','Dikerjakan','Selesai'];
            const statusOrder = ['menunggu_pembayaran','antrian','dikerjakan','selesai'];
            const currentIdx = statusOrder.indexOf(order.status);
            const isPast    = i < currentIdx;
            const isCurrent = i === currentIdx;
          %>
            <div class="flex items-center gap-3">
              <div class="w-6 h-6 rounded-full flex items-center justify-center shrink-0 text-xs
                          <%= isCurrent ? 'bg-indigo-600 text-white' : isPast ? 'bg-green-600/20 text-green-400' : 'bg-gray-800 text-gray-600' %>">
                <% if (isPast) { %>✓<% } else if (isCurrent) { %><%= i+1 %><% } else { %><%= i+1 %><% } %>
              </div>
              <span class="text-sm <%= isCurrent ? 'text-white font-medium' : isPast ? 'text-green-400' : 'text-gray-600' %>">
                <%= labels[i] %>
              </span>
            </div>
          <% }) %>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
  // ── Toggle upload wrapper ─────────────────────────────────────────────────
  const statusSel = document.getElementById('status-select');
  const uploadWrap = document.getElementById('result-upload-wrapper');

  statusSel.addEventListener('change', () => {
    uploadWrap.classList.toggle('hidden', statusSel.value !== 'selesai');
  });

  // ── File drop/click ───────────────────────────────────────────────────────
  const resultDrop = document.getElementById('result-drop');
  const resultInput = document.getElementById('result-file');
  const resultPlaceholder = document.getElementById('result-placeholder');
  const resultPreview = document.getElementById('result-preview');
  const rName = document.getElementById('r-name');
  const rIcon = document.getElementById('r-icon');

  resultDrop.addEventListener('click', e => {
    if (!e.target.closest('#r-remove')) resultInput.click();
  });

  resultDrop.addEventListener('dragover', e => {
    e.preventDefault();
    resultDrop.classList.add('border-indigo-500');
  });

  resultDrop.addEventListener('dragleave', () => resultDrop.classList.remove('border-indigo-500'));

  resultDrop.addEventListener('drop', e => {
    e.preventDefault();
    resultDrop.classList.remove('border-indigo-500');
    const file = e.dataTransfer.files[0];
    if (file) setResultFile(file);
  });

  resultInput.addEventListener('change', () => {
    if (resultInput.files[0]) setResultFile(resultInput.files[0]);
  });

  document.getElementById('r-remove').addEventListener('click', e => {
    e.stopPropagation();
    resultInput.value = '';
    resultPlaceholder.classList.remove('hidden');
    resultPreview.classList.add('hidden');
  });

  function setResultFile(file) {
    if (file.size > 2 * 1024 * 1024) { alert('Ukuran file maksimal 2MB'); return; }
    const icons = {
      'application/pdf': '📄', 'image/jpeg': '🖼️', 'image/png': '🖼️',
      'application/vnd.openxmlformats-officedocument.wordprocessingml.document': '📝'
    };
    rIcon.textContent = icons[file.type] || '📁';
    rName.textContent = file.name;
    resultPlaceholder.classList.add('hidden');
    resultPreview.classList.remove('hidden');
  }

  // ── Form submit validation ────────────────────────────────────────────────
  document.getElementById('update-form').addEventListener('submit', e => {
    const errEl = document.getElementById('form-err');
    errEl.classList.add('hidden');

    if (statusSel.value === 'selesai' && !resultInput.files[0] && !<%= !!order.result_file %>) {
      e.preventDefault();
      errEl.textContent = 'Upload file hasil wajib jika status "Selesai" dan belum ada file sebelumnya.';
      errEl.classList.remove('hidden');
      return;
    }

    const btn = document.getElementById('save-btn');
    const spin = document.getElementById('save-spin');
    document.getElementById('save-text').textContent = 'Menyimpan...';
    spin.classList.remove('hidden');
    btn.disabled = true;
  });

  // ── Download base64 helper ────────────────────────────────────────────────
  function downloadBase64(mime, b64, filename, e) {
    e.preventDefault();
    const link = document.createElement('a');
    link.href = `data:${mime};base64,${b64}`;
    link.download = filename;
    link.click();
  }
</script>
