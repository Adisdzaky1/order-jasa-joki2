<%# views/admin/pesanan-detail.ejs %>
<% title = 'Detail Pesanan #' + order.id.slice(0,8).toUpperCase() %>

<%
const STATUS_CONFIG = {
  menunggu_pembayaran: { cls:'bg-yellow-500/20 text-yellow-400 border-yellow-500/30', label:'Menunggu Pembayaran' },
  antrian:             { cls:'bg-blue-500/20 text-blue-400 border-blue-500/30',       label:'Antrian' },
  dikerjakan:          { cls:'bg-orange-500/20 text-orange-400 border-orange-500/30', label:'Dikerjakan' },
  selesai:             { cls:'bg-green-500/20 text-green-400 border-green-500/30',    label:'Selesai' },
};
const sc = STATUS_CONFIG[order.status] || { cls:'bg-gray-500/20 text-gray-400 border-gray-500/30', label: order.status };
const resultFiles = order.result_files || [];
%>

<%# ── Back + Header ──────────────────────────────────────────────────────── %>
<div class="mb-6">
  <a href="/admin/pesanan" class="inline-flex items-center gap-2 text-sm text-gray-400 hover:text-white transition-colors mb-4">
    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
    </svg>
    Kembali
  </a>
  <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-3">
    <div class="flex items-center gap-3 flex-wrap">
      <h1 class="text-2xl font-bold text-white">
        Pesanan <span class="font-mono text-indigo-400"><%= order.id.slice(0,8).toUpperCase() %></span>
      </h1>
      <span class="px-2.5 py-1 rounded-full text-xs font-semibold border <%= sc.cls %>">
        <%= sc.label %><% if(order.status==='antrian' && order.queue_number){ %> #<%= order.queue_number %><% } %>
      </span>
    </div>
    <p class="text-gray-500 text-xs">
      <%= new Date(order.created_at).toLocaleString('id-ID', {day:'numeric',month:'long',year:'numeric',hour:'2-digit',minute:'2-digit'}) %>
    </p>
  </div>
</div>

<%# ── 2-Column Layout ─────────────────────────────────────────────────────── %>
<div class="grid grid-cols-1 xl:grid-cols-5 gap-6">

  <%# ─── KOLOM KIRI ───────────────────────────────────────────────────────── %>
  <div class="xl:col-span-3 space-y-5">

    <%# Info Pesanan %>
    <div class="bg-gray-900 border border-gray-800 rounded-2xl p-6">
      <h2 class="text-xs font-semibold text-gray-500 uppercase tracking-wider mb-4">Info Pesanan</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 text-sm">
        <div>
          <p class="text-xs text-gray-500 mb-1">ID Pesanan</p>
          <p class="text-white font-mono text-xs bg-gray-800 px-3 py-2 rounded-lg break-all"><%= order.id %></p>
        </div>
        <div>
          <p class="text-xs text-gray-500 mb-1">Layanan</p>
          <p class="text-white font-medium"><%= order.service_name %></p>
        </div>
        <div>
          <p class="text-xs text-gray-500 mb-1">Harga Layanan</p>
          <p class="text-indigo-400 font-bold text-base">Rp <%= order.price.toLocaleString('id-ID') %></p>
        </div>
        <% if (order.grand_total) { %>
        <div>
          <p class="text-xs text-gray-500 mb-1">Total Dibayar</p>
          <p class="text-green-400 font-bold text-base">Rp <%= order.grand_total.toLocaleString('id-ID') %></p>
        </div>
        <% } %>
        <div>
          <p class="text-xs text-gray-500 mb-1">Metode Bayar</p>
          <p class="text-white uppercase"><%= order.payment_method || '—' %></p>
        </div>
        <div>
          <p class="text-xs text-gray-500 mb-1">Status Pembayaran</p>
          <% if (order.payment_status === 'success') { %>
            <span class="px-2.5 py-1 rounded-full text-xs font-semibold bg-green-500/20 text-green-400 border border-green-500/30">✅ Lunas</span>
          <% } else { %>
            <span class="px-2.5 py-1 rounded-full text-xs font-semibold bg-yellow-500/20 text-yellow-400 border border-yellow-500/30">⏳ Belum Bayar</span>
          <% } %>
        </div>
      </div>
    </div>

    <%# Info User %>
    <div class="bg-gray-900 border border-gray-800 rounded-2xl p-6">
      <h2 class="text-xs font-semibold text-gray-500 uppercase tracking-wider mb-4">Pelanggan</h2>
      <div class="flex items-center gap-4">
        <div class="w-11 h-11 rounded-full bg-indigo-600/20 flex items-center justify-center text-indigo-400 font-bold shrink-0">
          <%= (order.user_name || '?').charAt(0).toUpperCase() %>
        </div>
        <div>
          <p class="text-white font-semibold text-sm"><%= order.user_name || '—' %></p>
          <p class="text-gray-400 text-xs"><%= order.user_email %></p>
        </div>
      </div>
    </div>

    <%# Detail Tugas %>
    <div class="bg-gray-900 border border-gray-800 rounded-2xl p-6">
      <h2 class="text-xs font-semibold text-gray-500 uppercase tracking-wider mb-4">Detail Tugas</h2>
      <p class="text-xs text-gray-500 mb-1">Judul</p>
      <p class="text-white font-medium mb-4"><%= order.title %></p>
      <p class="text-xs text-gray-500 mb-1.5">Deskripsi</p>
      <p class="text-gray-300 text-sm leading-relaxed whitespace-pre-wrap bg-gray-800 rounded-xl p-4"><%= order.description %></p>
    </div>

    <%# Lampiran User %>
    <% if (order.attachment_file) { %>
    <div class="bg-gray-900 border border-gray-800 rounded-2xl p-6">
      <h2 class="text-xs font-semibold text-gray-500 uppercase tracking-wider mb-4">Lampiran Pelanggan</h2>
      <% const isImg = order.attachment_type && order.attachment_type.startsWith('image/'); %>
      <% if (isImg) { %>
        <div class="rounded-xl overflow-hidden border border-gray-700 mb-3 max-w-sm">
          <img src="data:<%= order.attachment_type %>;base64,<%= order.attachment_file %>" class="w-full h-auto max-h-56 object-contain"/>
        </div>
      <% } %>
      <div class="flex items-center gap-3 p-3.5 bg-gray-800 rounded-xl border border-gray-700">
        <span class="text-2xl"><%= order.attachment_type === 'application/pdf' ? '📄' : isImg ? '🖼️' : '📝' %></span>
        <div class="flex-1 min-w-0">
          <p class="text-sm text-white truncate"><%= order.attachment_name %></p>
          <p class="text-xs text-gray-500"><%= order.attachment_type %></p>
        </div>
        <a href="#" onclick="downloadBase64('<%= order.attachment_type %>','<%= order.attachment_file %>','<%= order.attachment_name %>',event)"
           class="px-3 py-1.5 bg-indigo-600 hover:bg-indigo-500 text-white text-xs font-semibold rounded-lg transition-colors shrink-0">
          Download
        </a>
      </div>
    </div>
    <% } %>

    <%# File Hasil yang sudah ada %>
    <% if (resultFiles.length > 0) { %>
    <div class="bg-gray-900 border border-green-800/50 rounded-2xl p-6">
      <div class="flex items-center justify-between mb-4">
        <h2 class="text-xs font-semibold text-green-400 uppercase tracking-wider">
          ✅ File Hasil (<%= resultFiles.length %> file)
        </h2>
      </div>
      <div class="space-y-2.5">
        <% resultFiles.forEach((file, fi) => { %>
          <div class="flex items-center gap-3 p-3.5 bg-gray-800 rounded-xl border border-gray-700 group">
            <span class="text-xl shrink-0"><%= getFileIcon(file.name) %></span>
            <div class="flex-1 min-w-0">
              <p class="text-sm text-white font-medium truncate"><%= file.name %></p>
              <p class="text-xs text-gray-500">
                <%= (file.size / 1024 / 1024).toFixed(2) %> MB ·
                <%= new Date(file.uploaded_at).toLocaleDateString('id-ID') %>
              </p>
            </div>
            <div class="flex items-center gap-2 shrink-0">
              <a href="/admin/orders/<%= order.id %>/download/<%= fi %>"
                 class="px-3 py-1.5 bg-green-600 hover:bg-green-500 text-white text-xs font-semibold rounded-lg transition-colors">
                ↓ Download
              </a>
              <form action="/admin/orders/<%= order.id %>/delete-file" method="POST"
                    onsubmit="return confirm('Hapus file ini?')">
                <input type="hidden" name="fileIdx" value="<%= fi %>"/>
                <button type="submit"
                        class="px-2 py-1.5 bg-red-900/50 hover:bg-red-600 text-red-400 hover:text-white text-xs font-semibold rounded-lg transition-colors border border-red-800">
                  Hapus
                </button>
              </form>
            </div>
          </div>
        <% }) %>
      </div>
    </div>
    <% } %>
  </div>

  <%# ─── KOLOM KANAN: Panel Kelola ────────────────────────────────────────── %>
  <div class="xl:col-span-2">
    <div class="bg-gray-900 border border-gray-800 rounded-2xl p-6 sticky top-6">
      <h2 class="text-xs font-semibold text-gray-500 uppercase tracking-wider mb-5">Panel Kelola</h2>

      <form id="update-form" action="/admin/orders/<%= order.id %>/update"
            method="POST" enctype="multipart/form-data" class="space-y-5">

        <%# Status %>
        <div>
          <label class="block text-sm font-medium text-gray-300 mb-2">Ubah Status</label>
          <select name="status" id="status-select"
                  class="w-full bg-gray-800 border border-gray-700 rounded-xl px-4 py-3 text-gray-100
                         focus:outline-none focus:border-indigo-500 transition-colors text-sm">
            <option value="menunggu_pembayaran" <%= order.status === 'menunggu_pembayaran' ? 'selected' : '' %>>⏳ Menunggu Pembayaran</option>
            <option value="antrian"             <%= order.status === 'antrian'             ? 'selected' : '' %>>🔵 Antrian</option>
            <option value="dikerjakan"          <%= order.status === 'dikerjakan'          ? 'selected' : '' %>>🟠 Sedang Dikerjakan</option>
            <option value="selesai"             <%= order.status === 'selesai'             ? 'selected' : '' %>>✅ Selesai</option>
          </select>
        </div>

        <%# Multi-file Upload %>
        <div id="upload-wrapper">
          <label class="block text-sm font-medium text-gray-300 mb-2">
            Upload File Hasil
            <span class="text-gray-500 font-normal text-xs ml-1">(semua format, maks 100MB/file)</span>
          </label>

          <%# Drop zone %>
          <div id="drop-zone"
               class="border-2 border-dashed border-gray-700 rounded-xl p-5 text-center cursor-pointer
                      hover:border-indigo-500 transition-colors group min-h-[100px] flex flex-col items-center justify-center">
            <input type="file" name="result_files" id="result-files" multiple class="hidden"/>
            <svg class="w-7 h-7 text-gray-600 mb-2 group-hover:text-indigo-400 transition-colors"
                 fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                    d="M7 16a4 4 0 01-.88-7.903A5 5 0 1115.9 6L16 6a5 5 0 011 9.9M15 13l-3-3m0 0l-3 3m3-3v12"/>
            </svg>
            <p class="text-xs text-gray-400">Klik atau drag & drop file</p>
            <p class="text-xs text-gray-600 mt-0.5">Bisa pilih lebih dari 1 file sekaligus</p>
          </div>

          <%# Preview list file yang dipilih %>
          <div id="file-list" class="mt-3 space-y-2 hidden"></div>
        </div>

        <div id="form-err" class="hidden p-3 bg-red-950 border border-red-800 rounded-xl text-xs text-red-400"></div>

        <button type="submit" id="save-btn"
                class="w-full bg-indigo-600 hover:bg-indigo-500 text-white font-semibold
                       py-3 rounded-xl transition-colors text-sm flex items-center justify-center gap-2">
          <span id="save-text">Simpan Perubahan</span>
          <svg id="save-spin" class="hidden w-4 h-4 animate-spin" fill="none" viewBox="0 0 24 24">
            <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"/>
            <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8v8H4z"/>
          </svg>
        </button>

        <% if (resultFiles.length > 0) { %>
          <p class="text-center text-xs text-gray-600">
            Sudah ada <%= resultFiles.length %> file. Upload baru akan ditambahkan, bukan mengganti.
          </p>
        <% } %>
      </form>

      <%# Progress status bar %>
      <div class="mt-6 pt-5 border-t border-gray-800">
        <h3 class="text-xs font-semibold text-gray-500 uppercase tracking-wider mb-3">Progress</h3>
        <div class="space-y-2">
          <% ['menunggu_pembayaran','antrian','dikerjakan','selesai'].forEach((s, i) => {
            const labels = ['Menunggu Pembayaran','Antrian','Dikerjakan','Selesai'];
            const statusOrder = ['menunggu_pembayaran','antrian','dikerjakan','selesai'];
            const curIdx = statusOrder.indexOf(order.status);
            const isPast    = i < curIdx;
            const isCurrent = i === curIdx;
          %>
            <div class="flex items-center gap-3">
              <div class="w-6 h-6 rounded-full flex items-center justify-center text-xs shrink-0
                          <%= isCurrent ? 'bg-indigo-600 text-white' : isPast ? 'bg-green-600 text-white' : 'bg-gray-800 text-gray-600' %>">
                <% if (isPast) { %>✓<% } else { %><%= i+1 %><% } %>
              </div>
              <span class="text-xs <%= isCurrent ? 'text-white font-medium' : isPast ? 'text-green-400' : 'text-gray-600' %>">
                <%= labels[i] %>
              </span>
            </div>
          <% }) %>
        </div>
      </div>
    </div>
  </div>
</div>

<%# Helper function untuk icon file %>
<script>
  // ── Drop zone ────────────────────────────────────────────────────────────────
  const dropZone   = document.getElementById('drop-zone');
  const fileInput  = document.getElementById('result-files');
  const fileList   = document.getElementById('file-list');
  let selectedFiles = [];

  dropZone.addEventListener('click', () => fileInput.click());

  dropZone.addEventListener('dragover', e => {
    e.preventDefault();
    dropZone.classList.add('border-indigo-500', 'bg-indigo-600/5');
  });
  dropZone.addEventListener('dragleave', () => {
    dropZone.classList.remove('border-indigo-500', 'bg-indigo-600/5');
  });
  dropZone.addEventListener('drop', e => {
    e.preventDefault();
    dropZone.classList.remove('border-indigo-500', 'bg-indigo-600/5');
    addFiles(Array.from(e.dataTransfer.files));
  });

  fileInput.addEventListener('change', () => {
    addFiles(Array.from(fileInput.files));
  });

  function addFiles(files) {
    files.forEach(f => {
      if (!selectedFiles.find(sf => sf.name === f.name && sf.size === f.size)) {
        selectedFiles.push(f);
      }
    });
    renderFileList();
    // Rebuild FileList — buat DataTransfer baru
    const dt = new DataTransfer();
    selectedFiles.forEach(f => dt.items.add(f));
    fileInput.files = dt.files;
  }

  function removeFile(idx) {
    selectedFiles.splice(idx, 1);
    renderFileList();
    const dt = new DataTransfer();
    selectedFiles.forEach(f => dt.items.add(f));
    fileInput.files = dt.files;
  }

  function renderFileList() {
    if (selectedFiles.length === 0) {
      fileList.classList.add('hidden');
      fileList.innerHTML = '';
      return;
    }
    fileList.classList.remove('hidden');
    fileList.innerHTML = selectedFiles.map((f, i) => `
      <div class="flex items-center gap-3 p-2.5 bg-gray-800 rounded-xl border border-gray-700">
        <span class="text-lg shrink-0">${fileIconEmoji(f.name)}</span>
        <div class="flex-1 min-w-0">
          <p class="text-xs text-white font-medium truncate">${f.name}</p>
          <p class="text-xs text-gray-500">${(f.size/1024/1024).toFixed(2)} MB</p>
        </div>
        <button type="button" onclick="removeFile(${i})"
                class="text-gray-500 hover:text-red-400 transition-colors p-1">
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
          </svg>
        </button>
      </div>`).join('');
  }

  function fileIconEmoji(name) {
    const ext = name.split('.').pop().toLowerCase();
    const icons = {
      pdf:'📄', doc:'📝', docx:'📝', xls:'📊', xlsx:'📊', ppt:'📋', pptx:'📋',
      jpg:'🖼️', jpeg:'🖼️', png:'🖼️', gif:'🖼️', webp:'🖼️',
      zip:'📦', rar:'📦', '7z':'📦',
      mp4:'🎬', avi:'🎬', mov:'🎬',
      mp3:'🎵', wav:'🎵',
      txt:'📃', md:'📃', js:'💻', py:'💻', html:'💻', css:'💻',
    };
    return icons[ext] || '📁';
  }

  // ── Form submit ──────────────────────────────────────────────────────────────
  document.getElementById('update-form').addEventListener('submit', e => {
    const btn  = document.getElementById('save-btn');
    const spin = document.getElementById('save-spin');
    const text = document.getElementById('save-text');
    const err  = document.getElementById('form-err');

    err.classList.add('hidden');

    const status = document.getElementById('status-select').value;
    const hasExisting = <%= resultFiles.length %> > 0;
    if (status === 'selesai' && selectedFiles.length === 0 && !hasExisting) {
      e.preventDefault();
      err.textContent = 'Upload minimal 1 file hasil jika status "Selesai".';
      err.classList.remove('hidden');
      return;
    }

    text.textContent = selectedFiles.length > 0
      ? `Mengupload ${selectedFiles.length} file...`
      : 'Menyimpan...';
    spin.classList.remove('hidden');
    btn.disabled = true;
  });

  // ── Download base64 (untuk lampiran user) ────────────────────────────────────
  function downloadBase64(mime, b64, filename, e) {
    e.preventDefault();
    const link = document.createElement('a');
    link.href = `data:${mime};base64,${b64}`;
    link.download = filename;
    link.click();
  }
</script>

<%# Server-side helper — karena EJS tidak punya fungsi JS build-in %>
<%
function getFileIcon(name) {
  const ext = (name || '').split('.').pop().toLowerCase();
  const icons = {
    pdf:'📄', doc:'📝', docx:'📝', xls:'📊', xlsx:'📊', ppt:'📋', pptx:'📋',
    jpg:'🖼️', jpeg:'🖼️', png:'🖼️', gif:'🖼️',
    zip:'📦', rar:'📦',
    mp4:'🎬', mp3:'🎵',
  };
  return icons[ext] || '📁';
}
%>
