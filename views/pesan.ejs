<%# views/pesan.ejs %>
<% title = 'Pesan - ' + service.name %>

<section class="py-12 max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">

  <%# Breadcrumb %>
  <div class="flex items-center gap-2 text-sm text-gray-500 mb-6">
    <a href="/layanan" class="hover:text-gray-300 transition-colors">Layanan</a>
    <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
    </svg>
    <span class="text-gray-300"><%= service.name %></span>
  </div>

  <%# Step Indicator %>
  <div class="flex items-center gap-0 mb-8">
    <% [['1','Detail Tugas'],['2','Pembayaran'],['3','Selesai']].forEach(([n,label],i) => { %>
      <div class="flex items-center <%= i < 2 ? 'flex-1' : '' %>">
        <div class="flex items-center gap-2">
          <div class="w-8 h-8 rounded-full flex items-center justify-center text-sm font-bold
                      <%= n==='1' ? 'bg-indigo-600 text-white' : 'bg-gray-800 text-gray-500 border border-gray-700' %>">
            <%= n %>
          </div>
          <span class="text-sm <%= n==='1' ? 'text-white font-medium' : 'text-gray-500' %> hidden sm:block"><%= label %></span>
        </div>
        <% if (i < 2) { %><div class="flex-1 h-px bg-gray-800 mx-3"></div><% } %>
      </div>
    <% }) %>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">

    <%# ── Form Kiri ──────────────────────────────────────────────────────────── %>
    <div class="lg:col-span-2">
      <div class="bg-gray-900 border border-gray-800 rounded-2xl p-6">
        <h2 class="text-lg font-semibold text-white mb-1">Detail Pesanan</h2>
        <% if (service.isCustom) { %>
          <p class="text-xs text-violet-400 mb-5">✨ Jasa Custom — Admin akan menghubungi Anda untuk konfirmasi harga setelah deposit masuk</p>
        <% } else { %>
          <p class="text-xs text-gray-500 mb-5">Isi semua detail agar kami dapat memproses pesanan dengan tepat</p>
        <% } %>

        <div id="form-error" class="hidden mb-4 p-3.5 bg-red-950 border border-red-800 rounded-xl text-sm text-red-400"></div>

        <%#
          PENTING: form TIDAK pakai enctype="multipart/form-data"
          File dikelola sepenuhnya lewat JS (FormData manual)
          sehingga tidak ada field file yang masuk dua kali ke multer
        %>
        <div class="space-y-5">
          <%# Hidden fields — dibaca JS saat submit %>
          <input type="hidden" id="h-service_id"   value="<%= service.id %>"/>
          <input type="hidden" id="h-service_name" value="<%= service.name %>"/>
          <input type="hidden" id="h-price"        value="<%= service.price %>"/>
          <input type="hidden" id="h-user_name"    value="<%= user && user.name ? user.name : '' %>"/>
          <input type="hidden" id="h-is_custom"    value="<%= service.isCustom ? '1' : '0' %>"/>

          <div>
            <label class="block text-sm font-medium text-gray-300 mb-2">
              Judul Tugas <span class="text-red-400">*</span>
            </label>
            <input type="text" id="f-title"
                   placeholder="<%= service.isCustom ? 'Contoh: Buat website landing page + desain logo' : 'Contoh: Skripsi S1 Manajemen Topik Digital Marketing' %>"
                   autocomplete="off"
                   class="w-full bg-gray-800 border border-gray-700 rounded-xl px-4 py-3 text-gray-100
                          focus:outline-none focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500 transition-colors text-sm"/>
          </div>

          <div>
            <label class="block text-sm font-medium text-gray-300 mb-2">
              Deskripsi Lengkap <span class="text-red-400">*</span>
            </label>
            <textarea id="f-desc" rows="5"
                      placeholder="<%= service.isCustom ? 'Ceritakan kebutuhan Anda secara detail: jenis pekerjaan, deadline, referensi, budget yang diinginkan, dll.' : 'Jelaskan: topik, halaman, format, deadline, instruksi khusus, dll.' %>"
                      class="w-full bg-gray-800 border border-gray-700 rounded-xl px-4 py-3 text-gray-100
                             focus:outline-none focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500
                             transition-colors text-sm resize-none"></textarea>
          </div>

          <%# ── Upload lampiran ─────────────────────────────────────────────── %>
          <div>
            <label class="block text-sm font-medium text-gray-300 mb-1">
              Lampiran
              <span class="text-gray-500 font-normal text-xs">— opsional · semua format · maks 100 MB/file · maks 10 file</span>
            </label>
            <p class="text-xs text-gray-600 mb-2">📁 File disimpan aman di GitHub repo kami</p>

            <%#
              KRITIS: <input> ini TIDAK punya atribut name=""
              Sehingga saat JS membangun FormData manual, tidak ada file yang terduplikasi.
              File hanya dikirim lewat fd.append('attachments', file) di JS submit.
            %>
            <div id="drop-zone"
                 class="border-2 border-dashed border-gray-700 rounded-xl p-6 text-center cursor-pointer
                        hover:border-indigo-500 hover:bg-indigo-600/5 transition-all group">
              <input type="file" id="file-picker" multiple accept="*/*" class="hidden"/>
              <svg class="w-9 h-9 text-gray-600 mx-auto mb-3 group-hover:text-indigo-400 transition-colors"
                   fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
                      d="M7 16a4 4 0 01-.88-7.903A5 5 0 1115.9 6L16 6a5 5 0 011 9.9M15 13l-3-3m0 0l-3 3m3-3v12"/>
              </svg>
              <p class="text-sm text-gray-300 font-medium group-hover:text-white transition-colors">Klik atau drag & drop file di sini</p>
              <p class="text-xs text-gray-500 mt-1">Semua format diterima (PDF, DOCX, JPG, ZIP, dll) · Bisa pilih lebih dari 1 file sekaligus</p>
            </div>
            <div id="file-list" class="mt-3 space-y-2 hidden"></div>
          </div>

          <% if (!user || !user.uid) { %>
            <div class="p-4 bg-yellow-500/10 border border-yellow-500/30 rounded-xl">
              <p class="text-sm text-yellow-400 font-medium mb-1">⚠️ Perlu Login</p>
              <p class="text-xs text-yellow-300/70">Login terlebih dahulu untuk melanjutkan pemesanan.</p>
            </div>
            <a href="/login?redirect=/pesan/<%= service.id %>"
               class="block w-full text-center bg-indigo-600 hover:bg-indigo-500 text-white font-semibold
                      py-3.5 rounded-xl transition-colors text-sm">
              Login untuk Memesan
            </a>
          <% } else { %>
            <button type="button" id="submit-btn"
                    class="w-full bg-indigo-600 hover:bg-indigo-500 text-white font-semibold py-3.5 rounded-xl
                           transition-colors text-sm flex items-center justify-center gap-2 disabled:opacity-50">
              <span id="submit-text">Lanjut ke Pembayaran →</span>
              <svg id="submit-spinner" class="hidden w-4 h-4 animate-spin" fill="none" viewBox="0 0 24 24">
                <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"/>
                <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8v8H4z"/>
              </svg>
            </button>
          <% } %>
        </div>
      </div>
    </div>

    <%# ── Ringkasan Kanan ─────────────────────────────────────────────────── %>
    <div class="lg:col-span-1">
      <div class="bg-gray-900 border border-gray-800 rounded-2xl p-5 sticky top-20">
        <div class="text-3xl mb-3"><%= service.icon %></div>
        <h3 class="font-semibold text-white mb-1"><%= service.name %></h3>
        <p class="text-sm text-gray-400 mb-4 leading-relaxed"><%= service.description %></p>

        <div class="border-t border-gray-800 pt-4 space-y-2.5 text-sm">
          <div class="flex justify-between">
            <span class="text-gray-400">Estimasi</span>
            <span class="text-gray-200 font-medium"><%= service.estimasi %></span>
          </div>
          <% if (service.isCustom) { %>
            <div class="flex justify-between">
              <span class="text-gray-400">Deposit awal</span>
              <span class="text-violet-400 font-bold">Rp 25.000</span>
            </div>
            <div class="p-3 bg-violet-600/10 border border-violet-500/20 rounded-xl mt-1">
              <p class="text-xs text-violet-300 leading-relaxed">
                💡 Bayar deposit Rp 25.000 untuk konfirmasi. Admin akan hubungi Anda untuk negosiasi harga final.
              </p>
            </div>
          <% } else { %>
            <div class="flex justify-between">
              <span class="text-gray-400">Harga</span>
              <span class="text-indigo-400 font-bold">Rp <%= service.price.toLocaleString('id-ID') %></span>
            </div>
          <% } %>
        </div>

        <% if (service.features && service.features.length > 0) { %>
          <div class="border-t border-gray-800 pt-4 mt-4">
            <h4 class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-3">Termasuk</h4>
            <ul class="space-y-2">
              <% service.features.forEach(f => { %>
                <li class="flex items-center gap-2 text-xs text-gray-400">
                  <svg class="w-3.5 h-3.5 text-green-400 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/>
                  </svg>
                  <%= f %>
                </li>
              <% }) %>
            </ul>
          </div>
        <% } %>
      </div>
    </div>
  </div>
</section>

<script>
// ── File management ──────────────────────────────────────────────────────────
const dropZone = document.getElementById('drop-zone');
const picker   = document.getElementById('file-picker');
const fileList = document.getElementById('file-list');
const errEl    = document.getElementById('form-error');
let files = []; // File[]

if (dropZone) {
  dropZone.addEventListener('click', () => picker.click());

  dropZone.addEventListener('dragover', e => {
    e.preventDefault();
    dropZone.classList.add('border-indigo-500', 'bg-indigo-600/5');
  });
  ['dragleave','drop'].forEach(ev => dropZone.addEventListener(ev, () =>
    dropZone.classList.remove('border-indigo-500', 'bg-indigo-600/5')));

  dropZone.addEventListener('drop', e => {
    e.preventDefault();
    addFiles([...e.dataTransfer.files]);
  });

  picker.addEventListener('change', () => {
    addFiles([...picker.files]);
    picker.value = ''; // reset agar bisa pilih file sama lagi
  });
}

function addFiles(newFiles) {
  hideErr();
  newFiles.forEach(f => {
    if (f.size > 100 * 1024 * 1024) {
      showErr(`"${f.name}" melebihi batas 100 MB dan dilewati.`);
      return;
    }
    if (files.length >= 10) { showErr('Maksimal 10 file.'); return; }
    if (!files.find(x => x.name === f.name && x.size === f.size)) files.push(f);
  });
  renderList();
}

function removeFile(i) { files.splice(i, 1); renderList(); }

const EXT_ICON = {
  pdf:'📄', doc:'📝', docx:'📝', xls:'📊', xlsx:'📊', ppt:'📋', pptx:'📋',
  jpg:'🖼️', jpeg:'🖼️', png:'🖼️', gif:'🖼️', webp:'🖼️', svg:'🖼️',
  zip:'📦', rar:'📦', '7z':'📦', tar:'📦', gz:'📦',
  mp4:'🎬', avi:'🎬', mov:'🎬', mp3:'🎵', wav:'🎵',
  txt:'📃', md:'📃', js:'💻', ts:'💻', py:'💻', html:'💻', css:'💻',
  json:'💻', xml:'💻', csv:'📊',
};
function icon(name) {
  const ext = (name || '').split('.').pop().toLowerCase();
  return EXT_ICON[ext] || '📁';
}
function fmtMB(bytes) { return (bytes / 1024 / 1024).toFixed(2) + ' MB'; }

function renderList() {
  if (!files.length) { fileList.classList.add('hidden'); fileList.innerHTML = ''; return; }
  fileList.classList.remove('hidden');
  const total = files.reduce((s, f) => s + f.size, 0);
  fileList.innerHTML = `
    <div class="flex justify-between text-xs text-gray-400 mb-1 px-1">
      <span>${files.length} file dipilih</span>
      <span>Total: ${fmtMB(total)}</span>
    </div>
    ${files.map((f, i) => `
    <div class="flex items-center gap-3 p-2.5 bg-gray-800 rounded-xl border border-gray-700">
      <span class="text-lg shrink-0">${icon(f.name)}</span>
      <div class="flex-1 min-w-0">
        <p class="text-xs text-white font-medium truncate">${f.name}</p>
        <p class="text-xs text-gray-500">${fmtMB(f.size)}</p>
      </div>
      <button type="button" onclick="removeFile(${i})"
              class="text-gray-500 hover:text-red-400 p-1 transition-colors shrink-0">
        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
        </svg>
      </button>
    </div>`).join('')}`;
}

function showErr(msg) { errEl.textContent = msg; errEl.classList.remove('hidden'); }
function hideErr()    { errEl.classList.add('hidden'); }

// ── Submit ───────────────────────────────────────────────────────────────────
const btn = document.getElementById('submit-btn');
if (btn) {
  btn.addEventListener('click', async () => {
    const spinner = document.getElementById('submit-spinner');
    const text    = document.getElementById('submit-text');
    hideErr();

    const title = (document.getElementById('f-title').value || '').trim();
    const desc  = (document.getElementById('f-desc').value  || '').trim();
    if (!title) return showErr('Judul tugas wajib diisi.');
    if (!desc)  return showErr('Deskripsi wajib diisi.');

    btn.disabled = true;
    spinner.classList.remove('hidden');
    text.textContent = files.length ? `Mengupload ${files.length} file...` : 'Memproses...';

    try {
      // Bangun FormData MANUAL — file input tidak punya name=""
      // sehingga tidak ada duplikasi ke multer
      const fd = new FormData();
      fd.append('service_id',   document.getElementById('h-service_id').value);
      fd.append('service_name', document.getElementById('h-service_name').value);
      fd.append('price',        document.getElementById('h-price').value);
      fd.append('user_name',    document.getElementById('h-user_name').value);
      fd.append('is_custom',    document.getElementById('h-is_custom').value);
      fd.append('title',        title);
      fd.append('description',  desc);

      // Setiap file dikirim dengan field name 'attachments'
      // sesuai multer config: upload.array('attachments', 10)
      files.forEach(f => fd.append('attachments', f, f.name));

      const res  = await fetch('/api/orders', { method: 'POST', body: fd });
      const data = await res.json();

      if (data.success) {
        text.textContent = 'Berhasil! Mengarahkan...';
        window.location.href = '/pembayaran/' + data.orderId;
      } else {
        throw new Error(data.error || 'Gagal membuat pesanan');
      }
    } catch (err) {
      showErr(err.message || 'Terjadi kesalahan, coba lagi.');
      btn.disabled = false;
      spinner.classList.add('hidden');
      text.textContent = 'Lanjut ke Pembayaran →';
    }
  });
}
</script>
