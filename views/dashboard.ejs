<%# views/dashboard.ejs %>
<% title = 'Dashboard Saya' %>

<%
function statusBadge(status, queueNumber) {
  const map = {
    menunggu_pembayaran: ['bg-yellow-500/20 text-yellow-400 border-yellow-500/30', 'Menunggu Pembayaran'],
    antrian:             ['bg-blue-500/20 text-blue-400 border-blue-500/30',   'Antrian'],
    dikerjakan:          ['bg-orange-500/20 text-orange-400 border-orange-500/30', 'Dikerjakan'],
    selesai:             ['bg-green-500/20 text-green-400 border-green-500/30', 'Selesai'],
  };
  const [cls, label] = map[status] || ['bg-gray-500/20 text-gray-400 border-gray-500/30', status];
  const extra = status === 'antrian' && queueNumber ? ` #${queueNumber}` : '';
  return `<span class="px-2.5 py-1 rounded-full text-xs font-semibold border ${cls}">${label}${extra}</span>`;
}
%>

<section class="py-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

  <%# ── Header ──────────────────────────────────────────────────────────────── %>
  <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4 mb-8">
    <div>
      <h1 class="text-2xl font-bold text-white">Halo, <%= user.name || 'Pengguna' %>! 👋</h1>
      <p class="text-gray-400 text-sm mt-1">Pantau semua pesanan Anda di sini</p>
    </div>
    <a href="/layanan"
       class="inline-flex items-center gap-2 px-5 py-2.5 bg-indigo-600 hover:bg-indigo-500 text-white font-semibold rounded-xl transition-colors text-sm">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
      </svg>
      Pesan Baru
    </a>
  </div>

  <%# ── Paid Success Banner ──────────────────────────────────────────────────── %>
  <% if (paid) { %>
    <div class="mb-6 p-4 bg-green-950 border border-green-800 rounded-2xl flex items-center gap-3">
      <div class="w-8 h-8 bg-green-600/20 rounded-full flex items-center justify-center shrink-0">
        <svg class="w-4 h-4 text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
        </svg>
      </div>
      <p class="text-sm text-green-300 font-medium">Pembayaran berhasil! Pesanan Anda sudah masuk antrian pengerjaan. 🎉</p>
    </div>
  <% } %>

  <%# ── Stats Cards ──────────────────────────────────────────────────────────── %>
  <div class="grid grid-cols-2 lg:grid-cols-4 gap-4 mb-8">
    <% [
      { label:'Total Pesanan', value: stats.total, icon:'📋', color:'indigo' },
      { label:'Menunggu',      value: stats.menunggu, icon:'⏳', color:'yellow' },
      { label:'Dikerjakan',    value: stats.dikerjakan, icon:'⚡', color:'orange' },
      { label:'Selesai',       value: stats.selesai, icon:'✅', color:'green' },
    ].forEach(s => { %>
      <div class="bg-gray-900 border border-gray-800 rounded-2xl p-5">
        <div class="text-2xl mb-2"><%= s.icon %></div>
        <p class="text-2xl font-extrabold text-white"><%= s.value %></p>
        <p class="text-xs text-gray-500 mt-0.5"><%= s.label %></p>
      </div>
    <% }) %>
  </div>

  <%# ── Orders Table ─────────────────────────────────────────────────────────── %>
  <div class="bg-gray-900 border border-gray-800 rounded-2xl overflow-hidden">
    <div class="px-6 py-4 border-b border-gray-800 flex items-center justify-between">
      <h2 class="text-base font-semibold text-white">Pesanan Saya</h2>
      <span class="text-xs text-gray-500"><%= orders.length %> pesanan</span>
    </div>

    <% if (orders.length === 0) { %>
      <div class="text-center py-16">
        <div class="text-4xl mb-4">📭</div>
        <h3 class="text-lg font-semibold text-white mb-2">Belum ada pesanan</h3>
        <p class="text-gray-400 text-sm mb-6">Mulai pesan layanan pertama Anda sekarang!</p>
        <a href="/layanan" class="inline-block px-6 py-2.5 bg-indigo-600 hover:bg-indigo-500 text-white font-semibold rounded-xl text-sm transition-colors">
          Lihat Layanan
        </a>
      </div>
    <% } else { %>
      <%# Desktop Table %>
      <div class="hidden md:block overflow-x-auto">
        <table class="w-full text-sm">
          <thead>
            <tr class="border-b border-gray-800">
              <th class="text-left text-xs font-semibold text-gray-500 uppercase tracking-wider px-6 py-3">No</th>
              <th class="text-left text-xs font-semibold text-gray-500 uppercase tracking-wider px-4 py-3">Layanan</th>
              <th class="text-left text-xs font-semibold text-gray-500 uppercase tracking-wider px-4 py-3">Judul</th>
              <th class="text-left text-xs font-semibold text-gray-500 uppercase tracking-wider px-4 py-3">Status</th>
              <th class="text-left text-xs font-semibold text-gray-500 uppercase tracking-wider px-4 py-3">Tanggal</th>
              <th class="text-left text-xs font-semibold text-gray-500 uppercase tracking-wider px-4 py-3">Aksi</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-800">
            <% orders.forEach((order, i) => { %>
              <tr class="hover:bg-gray-800/50 transition-colors">
                <td class="px-6 py-4 text-gray-400"><%= i + 1 %></td>
                <td class="px-4 py-4 text-gray-200 font-medium max-w-[180px] truncate"><%= order.service_name %></td>
                <td class="px-4 py-4 text-gray-400 max-w-[200px] truncate"><%= order.title %></td>
                <td class="px-4 py-4"><%- statusBadge(order.status, order.queue_number) %></td>
                <td class="px-4 py-4 text-gray-500 whitespace-nowrap">
                  <%= new Date(order.created_at).toLocaleDateString('id-ID', {day:'numeric',month:'short',year:'numeric'}) %>
                </td>
                <td class="px-4 py-4">
                  <div class="flex items-center gap-2">
                    <button onclick="openModal('<%= order.id %>')"
                            class="text-xs text-indigo-400 hover:text-indigo-300 font-medium transition-colors">
                      Detail
                    </button>
                    <% if (order.status === 'selesai' && order.result_file) { %>
                      <a href="#" onclick="downloadResult('<%= order.id %>', '<%= order.result_filename || 'hasil.pdf' %>', '<%= order.result_filetype || '' %>', event)"
                         class="text-xs text-green-400 hover:text-green-300 font-medium transition-colors">
                        Download ↓
                      </a>
                    <% } %>
                    <% if (order.payment_status === 'pending' && order.atlantic_tx_id) { %>
                      <a href="/pembayaran/<%= order.id %>"
                         class="text-xs text-yellow-400 hover:text-yellow-300 font-medium transition-colors">
                        Bayar
                      </a>
                    <% } %>
                  </div>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>

      <%# Mobile Card List %>
      <div class="md:hidden divide-y divide-gray-800">
        <% orders.forEach(order => { %>
          <div class="p-4">
            <div class="flex items-start justify-between mb-2">
              <div class="flex-1 min-w-0 mr-3">
                <p class="text-sm font-medium text-white truncate"><%= order.service_name %></p>
                <p class="text-xs text-gray-400 truncate mt-0.5"><%= order.title %></p>
              </div>
              <%- statusBadge(order.status, order.queue_number) %>
            </div>
            <div class="flex items-center justify-between mt-2">
              <p class="text-xs text-gray-500">
                <%= new Date(order.created_at).toLocaleDateString('id-ID') %>
              </p>
              <div class="flex gap-3">
                <button onclick="openModal('<%= order.id %>')" class="text-xs text-indigo-400 font-medium">Detail</button>
                <% if (order.status === 'selesai' && order.result_file) { %>
                  <a href="#" onclick="downloadResult('<%= order.id %>', '<%= order.result_filename || 'hasil.pdf' %>', '<%= order.result_filetype || '' %>', event)"
                     class="text-xs text-green-400 font-medium">Download</a>
                <% } %>
              </div>
            </div>
          </div>
        <% }) %>
      </div>
    <% } %>
  </div>
</section>

<%# ── Detail Modal ──────────────────────────────────────────────────────────── %>
<div id="order-modal" class="fixed inset-0 z-50 hidden">
  <div class="absolute inset-0 bg-black/70 backdrop-blur-sm" onclick="closeModal()"></div>
  <div class="absolute inset-0 flex items-center justify-center p-4">
    <div class="relative bg-gray-900 border border-gray-800 rounded-2xl w-full max-w-md max-h-[90vh] overflow-y-auto">

      <%# Header modal %>
      <div class="flex items-center justify-between px-6 py-4 border-b border-gray-800 sticky top-0 bg-gray-900 rounded-t-2xl z-10">
        <h3 class="text-base font-semibold text-white" id="modal-title">Detail Pesanan</h3>
        <button onclick="closeModal()" class="text-gray-500 hover:text-white transition-colors">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
          </svg>
        </button>
      </div>

      <%# Tab nav %>
      <div class="flex border-b border-gray-800" id="modal-tabs">
        <button onclick="switchTab('info')" id="tab-info"
                class="flex-1 py-2.5 text-xs font-semibold text-white border-b-2 border-indigo-500 transition-colors">
          Info Pesanan
        </button>
        <button onclick="switchTab('payment')" id="tab-payment"
                class="flex-1 py-2.5 text-xs font-semibold text-gray-500 border-b-2 border-transparent hover:text-gray-300 transition-colors">
          Pembayaran
        </button>
      </div>

      <%# Tab: Info %>
      <div id="panel-info" class="p-5 space-y-3 text-sm"></div>

      <%# Tab: Pembayaran %>
      <div id="panel-payment" class="p-5 hidden text-sm"></div>

    </div>
  </div>
</div>

<%# Inject order data %>
<script>
  const ORDERS = <%- JSON.stringify(orders.map(o => ({
    id: o.id,
    service_name: o.service_name,
    title: o.title,
    description: o.description,
    price: o.price,
    grand_total: o.grand_total || null,
    fee_flat: o.fee_flat || null,
    fee_percent: o.fee_percent || null,
    fee_total: o.fee_total || null,
    status: o.status,
    payment_status: o.payment_status,
    payment_method: o.payment_method || null,
    atlantic_tx_id: o.atlantic_tx_id || null,
    atlantic_qr_image: o.atlantic_qr_image || null,
    atlantic_expired_at: o.atlantic_expired_at || null,
    queue_number: o.queue_number,
    result_file: !!o.result_file,
    result_filename: o.result_filename,
    result_filetype: o.result_filetype,
    created_at: o.created_at,
    attachment_name: o.attachment_name,
  }))) %>;

  const STATUS_LABEL = {
    menunggu_pembayaran: '⏳ Menunggu Pembayaran',
    antrian:             '🔵 Dalam Antrian',
    dikerjakan:          '🟠 Sedang Dikerjakan',
    selesai:             '✅ Selesai',
  };

  let currentOrderId = null;
  let pollTimer = null;
  let countdownTimer = null;

  // ── Tab switch ──────────────────────────────────────────────────────────────
  function switchTab(tab) {
    const isInfo = tab === 'info';
    document.getElementById('panel-info').classList.toggle('hidden', !isInfo);
    document.getElementById('panel-payment').classList.toggle('hidden', isInfo);
    document.getElementById('tab-info').className =
      `flex-1 py-2.5 text-xs font-semibold transition-colors ${isInfo ? 'text-white border-b-2 border-indigo-500' : 'text-gray-500 border-b-2 border-transparent hover:text-gray-300'}`;
    document.getElementById('tab-payment').className =
      `flex-1 py-2.5 text-xs font-semibold transition-colors ${!isInfo ? 'text-white border-b-2 border-indigo-500' : 'text-gray-500 border-b-2 border-transparent hover:text-gray-300'}`;
  }

  // ── Open modal ──────────────────────────────────────────────────────────────
  function openModal(id) {
    const o = ORDERS.find(x => x.id === id);
    if (!o) return;
    currentOrderId = id;

    document.getElementById('modal-title').textContent = o.service_name;
    renderInfoTab(o);
    renderPaymentTab(o);
    switchTab('info');

    document.getElementById('order-modal').classList.remove('hidden');
    document.body.style.overflow = 'hidden';
  }

  function closeModal() {
    clearInterval(pollTimer);
    clearInterval(countdownTimer);
    document.getElementById('order-modal').classList.add('hidden');
    document.body.style.overflow = '';
    currentOrderId = null;
  }

  // ── Info Tab ────────────────────────────────────────────────────────────────
  function renderInfoTab(o) {
    const fmt = n => 'Rp ' + Number(n).toLocaleString('id-ID');
    const statusLabel = STATUS_LABEL[o.status] || o.status;
    const queueExtra  = o.status === 'antrian' && o.queue_number ? ` #${o.queue_number}` : '';

    document.getElementById('panel-info').innerHTML = `
      <div class="grid grid-cols-2 gap-2.5">
        <div class="bg-gray-800 rounded-xl p-3 col-span-2">
          <p class="text-xs text-gray-500 mb-1">Judul Tugas</p>
          <p class="text-white font-medium text-sm">${o.title}</p>
        </div>
        <div class="bg-gray-800 rounded-xl p-3 col-span-2">
          <p class="text-xs text-gray-500 mb-1">Deskripsi</p>
          <p class="text-gray-300 text-xs leading-relaxed whitespace-pre-wrap">${o.description}</p>
        </div>
        <div class="bg-gray-800 rounded-xl p-3">
          <p class="text-xs text-gray-500 mb-1">Harga Layanan</p>
          <p class="text-indigo-400 font-bold">${fmt(o.price)}</p>
        </div>
        <div class="bg-gray-800 rounded-xl p-3">
          <p class="text-xs text-gray-500 mb-1">Status</p>
          <p class="text-white text-xs font-medium">${statusLabel}${queueExtra}</p>
        </div>
        <div class="bg-gray-800 rounded-xl p-3 col-span-2">
          <p class="text-xs text-gray-500 mb-1">Tanggal Pesan</p>
          <p class="text-white text-xs">${new Date(o.created_at).toLocaleString('id-ID')}</p>
        </div>
        ${o.attachment_name ? `
          <div class="bg-gray-800 rounded-xl p-3 col-span-2">
            <p class="text-xs text-gray-500 mb-1">Lampiran</p>
            <p class="text-gray-300 text-xs">📎 ${o.attachment_name}</p>
          </div>` : ''}
        ${o.result_file ? `
          <div class="col-span-2 pt-1">
            <button onclick="downloadResult('${o.id}','${o.result_filename||'hasil.pdf'}','${o.result_filetype||''}')"
                    class="w-full py-2.5 bg-green-600 hover:bg-green-500 text-white font-semibold rounded-xl text-sm transition-colors">
              ⬇ Download Hasil
            </button>
          </div>` : ''}
        ${o.payment_status !== 'success' ? `
          <div class="col-span-2 pt-1">
            <button onclick="switchTab('payment')"
                    class="w-full py-2.5 bg-yellow-600 hover:bg-yellow-500 text-white font-semibold rounded-xl text-sm transition-colors">
              💳 Bayar Sekarang
            </button>
          </div>` : ''}
      </div>`;
  }

  // ── Payment Tab ─────────────────────────────────────────────────────────────
  function renderPaymentTab(o) {
    const fmt = n => 'Rp ' + Number(n).toLocaleString('id-ID');
    const panel = document.getElementById('panel-payment');

    // Sudah lunas
    if (o.payment_status === 'success') {
      panel.innerHTML = `
        <div class="text-center py-8">
          <div class="w-14 h-14 bg-green-600/20 rounded-full flex items-center justify-center mx-auto mb-3">
            <svg class="w-7 h-7 text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
            </svg>
          </div>
          <p class="text-green-400 font-semibold mb-1">Pembayaran Lunas</p>
          <p class="text-gray-400 text-xs">Pesanan Anda sedang diproses</p>
        </div>`;
      return;
    }

    // QR sudah dibuat, tinggal scan
    if (o.atlantic_qr_image && o.payment_status === 'pending' && o.payment_method === 'qris') {
      renderQRPanel(o, panel);
      startPolling(o.id);
      startCountdown(o.atlantic_expired_at);
      return;
    }

    // Belum buat tagihan → tampilkan ringkasan fee + tombol buat QRIS
    const feeFlat    = 1000;
    const feePercent = Math.ceil(o.price * 0.007);
    const feeTotal   = feeFlat + feePercent;
    const grandTotal = o.price + feeTotal;

    panel.innerHTML = `
      <div class="space-y-3">
        <p class="text-xs text-gray-400 mb-3">Bayar dengan <span class="text-white font-semibold">QRIS</span> — scan dari aplikasi apapun</p>

        <%# Rincian harga %>
        <div class="bg-gray-800 rounded-xl p-4 space-y-2 text-xs">
          <div class="flex justify-between text-gray-400">
            <span>Harga layanan</span><span class="text-white">${fmt(o.price)}</span>
          </div>
          <div class="flex justify-between text-gray-400">
            <span>Biaya admin</span><span class="text-white">${fmt(feeFlat)}</span>
          </div>
          <div class="flex justify-between text-gray-400">
            <span>Biaya QRIS (0,7%)</span><span class="text-white">${fmt(feePercent)}</span>
          </div>
          <div class="border-t border-gray-700 pt-2 flex justify-between font-semibold">
            <span class="text-gray-300">Total Bayar</span>
            <span class="text-indigo-400 text-sm">${fmt(grandTotal)}</span>
          </div>
        </div>

        <div id="pay-error" class="hidden p-3 bg-red-950 border border-red-800 rounded-xl text-xs text-red-400"></div>

        <button onclick="createQRIS('${o.id}')" id="btn-create-qr"
                class="w-full py-3 bg-indigo-600 hover:bg-indigo-500 text-white font-semibold rounded-xl text-sm transition-colors flex items-center justify-center gap-2">
          <span id="btn-create-text">Buat QRIS & Bayar</span>
          <svg id="btn-create-spin" class="hidden w-4 h-4 animate-spin" fill="none" viewBox="0 0 24 24">
            <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"/>
            <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8v8H4z"/>
          </svg>
        </button>
        <p class="text-center text-xs text-gray-600">QR berlaku 60 menit setelah dibuat</p>
      </div>`;
  }

  function renderQRPanel(o, panel) {
    const fmt = n => 'Rp ' + Number(n).toLocaleString('id-ID');
    panel.innerHTML = `
      <div class="text-center space-y-3">
        <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-yellow-500/10 border border-yellow-500/20 text-yellow-400 text-xs font-medium">
          <span class="w-1.5 h-1.5 rounded-full bg-yellow-400 animate-pulse"></span>
          Menunggu Pembayaran
        </div>

        <p class="text-xs text-gray-400">Scan QR dengan aplikasi e-wallet atau mobile banking</p>

        <div class="inline-block p-3 bg-white rounded-2xl">
          <img src="${o.atlantic_qr_image}" alt="QRIS" class="w-44 h-44 object-contain"/>
        </div>

        <div>
          <p class="text-lg font-bold text-white">${fmt(o.grand_total || o.price)}</p>
          ${o.fee_total ? `<p class="text-xs text-gray-500">sudah termasuk biaya Rp ${Number(o.fee_total).toLocaleString('id-ID')}</p>` : ''}
        </div>

        <div class="flex items-center justify-center gap-2 text-xs text-gray-500">
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
          </svg>
          Berlaku: <span id="modal-countdown" class="font-mono text-white font-semibold">--:--</span>
        </div>

        <div id="modal-poll-status" class="flex items-center justify-center gap-1.5 text-xs text-gray-500">
          <svg class="w-3.5 h-3.5 animate-spin text-indigo-400" fill="none" viewBox="0 0 24 24">
            <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"/>
            <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8v8H4z"/>
          </svg>
          Memeriksa status...
        </div>
      </div>`;
  }

  // ── Create QRIS ─────────────────────────────────────────────────────────────
  async function createQRIS(orderId) {
    const btn  = document.getElementById('btn-create-qr');
    const text = document.getElementById('btn-create-text');
    const spin = document.getElementById('btn-create-spin');
    const err  = document.getElementById('pay-error');
    if (err) err.classList.add('hidden');
    if (btn) btn.disabled = true;
    if (text) text.textContent = 'Memproses...';
    if (spin) spin.classList.remove('hidden');

    try {
      const res = await fetch('/api/payment/create', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ orderId, metode: 'qris' }),
      });
      const data = await res.json();
      if (!data.success) throw new Error(data.error || 'Gagal membuat tagihan');

      // Update order di local state
      const o = ORDERS.find(x => x.id === orderId);
      if (o) {
        o.atlantic_qr_image  = data.qr_image;
        o.atlantic_expired_at = data.expired_at;
        o.payment_method     = 'qris';
        o.payment_status     = 'pending';
        o.grand_total        = data.grand_total;
        o.fee_total          = data.fee_total;
      }

      const panel = document.getElementById('panel-payment');
      renderQRPanel(o, panel);
      startPolling(orderId);
      startCountdown(data.expired_at);
    } catch (e) {
      if (err) { err.textContent = e.message; err.classList.remove('hidden'); }
      if (btn) btn.disabled = false;
      if (text) text.textContent = 'Buat QRIS & Bayar';
      if (spin) spin.classList.add('hidden');
    }
  }

  // ── Countdown ────────────────────────────────────────────────────────────────
  function startCountdown(expiredAt) {
    clearInterval(countdownTimer);
    const expiry = new Date(expiredAt).getTime();
    countdownTimer = setInterval(() => {
      const el = document.getElementById('modal-countdown');
      if (!el) return clearInterval(countdownTimer);
      const rem = expiry - Date.now();
      if (rem <= 0) { el.textContent = '00:00'; el.classList.add('text-red-400'); return; }
      const m = Math.floor(rem / 60000);
      const s = Math.floor((rem % 60000) / 1000);
      el.textContent = String(m).padStart(2,'0') + ':' + String(s).padStart(2,'0');
      if (rem < 120000) el.classList.add('text-red-400');
    }, 1000);
  }

  // ── Polling ──────────────────────────────────────────────────────────────────
  function startPolling(orderId) {
    clearInterval(pollTimer);
    pollTimer = setInterval(async () => {
      try {
        const res = await fetch('/api/payment/status/' + orderId);
        const data = await res.json();
        if (data.payment_status === 'success') {
          clearInterval(pollTimer);
          clearInterval(countdownTimer);

          // Update local state
          const o = ORDERS.find(x => x.id === orderId);
          if (o) { o.payment_status = 'success'; o.status = 'antrian'; }

          // Update badge di tabel
          updateRowBadge(orderId, 'antrian');

          // Tampilkan sukses
          const panel = document.getElementById('panel-payment');
          if (panel) panel.innerHTML = `
            <div class="text-center py-8">
              <div class="w-14 h-14 bg-green-600/20 rounded-full flex items-center justify-center mx-auto mb-3">
                <svg class="w-7 h-7 text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
                </svg>
              </div>
              <p class="text-green-400 font-semibold mb-1">Pembayaran Berhasil! 🎉</p>
              <p class="text-gray-400 text-xs mb-4">Pesanan masuk antrian pengerjaan</p>
              <button onclick="closeModal()" class="px-5 py-2 bg-indigo-600 hover:bg-indigo-500 text-white text-sm font-semibold rounded-xl transition-colors">Tutup</button>
            </div>`;
        }
      } catch { /* silent */ }
    }, 5000);
  }

  // ── Update row badge tanpa reload ────────────────────────────────────────────
  function updateRowBadge(orderId, status) {
    const BADGE = {
      antrian: 'px-2.5 py-1 rounded-full text-xs font-semibold border bg-blue-500/20 text-blue-400 border-blue-500/30',
    };
    const LABEL = { antrian: 'Antrian' };
    document.querySelectorAll(`[data-order-id="${orderId}"] .status-badge`).forEach(el => {
      el.className = BADGE[status] || '';
      el.textContent = LABEL[status] || status;
    });
  }

  // ── Download result ──────────────────────────────────────────────────────────
  async function downloadResult(orderId, filename, filetype) {
    try {
      const res  = await fetch('/api/orders/' + orderId);
      const data = await res.json();
      if (!data.order?.result_file) return alert('File tidak tersedia');
      const link = document.createElement('a');
      link.href = `data:${filetype||'application/octet-stream'};base64,${data.order.result_file}`;
      link.download = filename;
      link.click();
    } catch { alert('Gagal mengunduh file'); }
  }

  document.addEventListener('keydown', e => { if (e.key === 'Escape') closeModal(); });
</script>
